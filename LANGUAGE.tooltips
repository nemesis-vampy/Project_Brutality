[enu default]

//ALL THEM TOOLTIPS
//[AD]
//Multiplayer options
TIP_PB_FORCESPMOVEMENT = "Multiplayer movement is 33% slower than singleplayer and disables dashing.";
TIP_PB_MPCALLSIGN = "Callsigns are three letter, uppercase names that appear instead of your full nickname.";

//HUD options
TIP_PB_SHOWLEVELSTATS = "Show time, kills, items, and secrets on the HUD.";
TIP_PB_SHOWAMMOLIST = "Show reserve ammo on the HUD.";
TIP_PB_CURMAXAMMOLIST = "Show maximum amount next to the current amount.";
TIP_PB_HIDEUNUSEDTYPES = "Hide ammo and equipment until it has been discovered.";
TIP_ZM_SPEEDOMETER = "Show a speedometer in Quake or Doom mapunits.";
TIP_PB_EXECUTION_BOX = "When an enemy can be executed, display an icon over it.";
TIP_PB_EXECUTION_INDICATORTYPE = "Graphic to display for execution indicator.";
TIP_PB_HUDXMARGIN = "Distance the HUD should be offset from the sides of the screen.";
TIP_PB_HUDYMARGIN = "Distance the HUD should be offset from the top and bottom of the screen.";
TIP_PB_HUDBOXALPHA = "Opacity of background HUD elements.";
TIP_PB_MESSAGESIZE = "Size of console messages.";
TIP_PB_USELOWRESHUDFONT = "Better on low resolution displays.";
TIP_PB_DASHEFFECT = "Toggles the screen effect when performing a dash.";
TIP_PB_LOWFLASHESMODE = "Significantly lower flashing effects when a powerup is running out.";
TIP_PB_SHOWBLOODDROPS = "Enable blood splashing on the screen.";
TIP_PB_BLOODDROPSALPHA = "Opacity of blood splashes.";
TIP_PB_SHOWGLASSCRACKS = "Enable glass cracking effects from taking damage.";
TIP_PB_GLASSCRACKSALPHA = "Opacity of glass cracks.";
TIP_PB_SHOWHUDVISOR = "Render visor graphics.";
TIP_PB_SHOWHUDVISORGLASS = "Render visor glass graphics.";
TIP_PB_HUDALPHA = "Opacity of visor glass.";
TIP_PB_VISORMIDDLEPARTBOTTOM = "Move central visor part to the bottom of the screen.";
TIP_PB_HUDDYNAMICS = "HUD will sway with movement and aiming.";
TIP_PB_NEWMUGSHOT = "Disable the custom mugshot if you prefer vanilla, or are using a custom mugshot mod.";
TIP_PB_WEAPON_CROSSHAIRS = "Unique crosshair for each weapon. Overrides custom crosshair setting.";
TIP_HUD_OLDSCALE = "Disable if your HUD is too big or too small. Also allows finer scaling.";
TIP_HUD_SCALEFACTOR = "Set to 0.99 for smoother swaying.";

//Tilt++ options
TIP_SV_STRAFETILT = "Enable strafe tilting.";
TIP_SV_STRAFETILTINVERT = "Invert the strafe tilting direction.";
TIP_SV_STRAFETILTSPEED = "How fast strafe tilting occurs.";
TIP_SV_STRAFETILTANGLE = "Maximum angle to tilt the view while strafing.";
TIP_SV_MOVETILT = "Enable movement tilting.";
TIP_SV_MOVETILTSPEED = "How fast to tilt the view while moving.";
TIP_SV_MOVETILTANGLE = "Maximum movement tilting angle.";
TIP_SV_MOVETILTSCALAR = "Overall movement tilting intensity.";
TIP_SV_TURNTILT = "Enable horizontal-look tilting.";
TIP_SV_TURNTILTINVERT = "Invert the turn tilting direction.";
TIP_SV_TURNTILTSCALAR = "Overall turn tilting intensity.";
TIP_SV_UNDERWATERTILT = "Enable slow tilting while submerged underwater.";
TIP_SV_UNDERWATERTILTSPEED = "How fast to tilt the view while underwater.";
TIP_SV_UNDERWATERTILTANGLE = "Maximum underwater tilting angle.";
TIP_SV_UNDERWATERTILTSCALAR = "Overall underwater tilting intensity.";
TIP_SV_DEATHTILT = "Tilt the view when player is dead.";

//Spawn options
TIP_SPAWNBALANCE = "How monster and item spaws are determined.";
TIP_LEVELSTOPLAY = "Number of levels in the mapset you're playing. Only affects Dynamic and Tiered Progression modes.";

TIP_PB_NOUPGRADES = "Backpacks spawn weapon upgrades.";
TIP_PB_MG42WOLFSPAWNER = "MG42 can only spawn in maps containing Wolfenstein SS.";
TIP_PB_SSGRandomSpawn = "Super Shotguns have a chance to replace Shotguns.";

TIP_PB_VANILLAMONSTER_OVERRIDE = "Disable PB's Monsters, for those that are running custom enemy packs specifically.";
TIP_PB_VANILLAWOLFSS_OVERRIDE = "Replace nazis with vanilla Wolfenstein SS, for maps that use them to make custom enemies in DeHackEd.";
TIP_PB_VANILLABOSSBRAIN_OVERRIDE = "Disable PB's custom Final Boss, for maps that use it in DeHackEd.";

//Gameplay options
TIP_SINGLEDUALFIRE = "Single Button - Primary fire button fires both weapons, similar to BDv21.\nDefault - Primary fire: Fire left weapon, Alt-fire: Fire right weapon.\nInverted - Primary fire: Fire right weapon, Alt-fire: Fire left weapon.";
TIP_PB_TOGGLE_AIM_HOLD = "Whether tapping or holding will switch ADS modes.";
TIP_PB_BD_SLIDE = "No - Use Crouch and Run to slide.\nYes - Use Crouch and Kick to slide.";
TIP_PB_WEAPON_RECOIL_MOD_VERTICAL = "Adjust recoil. 1.0 is normal recoil. Set to 0 to disable or higher for higher recoil.";
TIP_PB_WEAPON_RECOIL_MOD_HORIZONTAL = "Adjust recoil. 1.0 is normal recoil. Set to 0 to disable or higher for higher recoil.";
TIP_PB_HAZARDMOVEMENT = "Disables jumping, sliding and dashing when standing on damaging floors. Turn this off for maps where advanced movement is not intended.";
TIP_PLAYERCATCHUP = "Your inventory will be returned to you after a death exit. May not work with some maps.";
TIP_PB_QSGQUADLOAD = "Load all four shells into the Quad Shotgun at once.";
TIP_PB_DISABLE_WALL_PENETRATION = "Disable wall penetration if you encounter progression breaking issues.";
TIP_PB_DISABLE_DECORATIONS = "Disable Project Brutality's custom decorations.";
TIP_PB_DECORATIVE_FLAME_BARRELS = "Replace explosive flaming barrels with decorative ones, like vanilla.";
TIP_PB_NOHELMETANIMATION = "Disable the animation of putting on your helmet at the start of the game.";
TIP_NODOOMGUYTALK = "Disables the chance for automatic taunts to play.";
TIP_PB_NAILLIFETIME = "Time in seconds before nails despawn.";
TIP_PB_SIMPLEMONSTERBEHAVIOR = "Simplified monster behavior more in line with vanilla.";

//Visual options
CL_MAXDECALS = "Maximum number of wall decals that can exist at once.";
TIP_PB_PERFORMANCE_FIRE = "Use less effects for Flamethrower fire.";
TIP_PB_GUNSMOKETYPE = "Which muzzle smoke particle effect to use.";
TIP_PB_EXAGGERATEDRECOIL = "Exaggerated recoil for fully automatic weapons, the camera will sway around and tilt while firing.";
TIP_PB_EXAGGERATEDRECOILMUL = "Intensity of recoil.";
TIP_PB_TRACERLIGHT = "Enables GL light emitted from tracers.";
TIP_PB_POWERUP_SHADERS = "Use shaders for prettier powerup effects.";
TIP_PB_NIGHTVISION_EXPOSURE = "Brightness of the night vision effect. Values above 0 will be automatically dimmed in bright sectors.";
TIP_PB_CYBERDEMONDEATH = "Skip the Cyberdemon's death animation.";

//PBVP options
TIP_V5_MODELS = "Replaces Pickups/Casings/Decor with Voxel-Style PolyMesh Models.\nModels may cause performance issues.\nYou can switch this feature On or Off at any time.";
TIP_V5_CULL = "Models will only render in when near the player.";
TIP_V5_MDIST = "Range at which models stop rendering.";
TIP_V5_QUAKE3 = "Makes Weapons, Keys, and small pickups float and spin a la Quake 3.";
TIP_V5_Q3SPIN = "Speed and direction of spin.";
TIP_V5_Q3ZOFF = "Height that items float above the ground.";
TIP_V5_Q3BOB = "Range items will bob up and down in.";

//Motion blur options
TIP_MBLUR = "Enable motion blur.";
TIP_MBLUR_SAMPLES = "Smoothness of blur.";
TIP_MBLUR_STRENGTH = "Length blur stretches.";
TIP_MBLUR_RECOVERY = "How long blur stays on screen.";

//Weapon visual options
TIP_PB_PIXELRENDERINGFIX = "Project Brutality's weapons were not designed for the 20% vertical stretch of vanilla doom's rendering.\nYou can re-enable it if you prefer the vanilla look.";
TIP_MOVEBOB = "Adjust view bobbing's intensity when moving";
TIP_STILLBOB = "Adjust view bobbing's intensity when not moving";
TIP_WBOBSPEED = "Adjust weapon bobbing's intensity when moving";
TIP_PB_STILLBOB = "Turn on/off the weapon bobbing when standing still";
TIP_PB_FULLBOBSPEED = "How fast weapon sprites transition to their maximum bobbing range";
TIP_PB_YAWSWAY = "Allow weapons to sway according to your mouse yaw";
TIP_PB_YAWSWAYSPEED = "How fast weapons sway";
TIP_PB_YAWSWAYRANGE = "Maximum Distance weapons can sway";
TIP_PB_YAWSWAYFRICTION = "How fast sprites will tend to realign to the center";
TIP_PB_YAWSWAYDIRECTION = "Set wherever weapons sway in the direction you turn or the opposite";
TIP_PB_PITCHSWAYTYPE = "Set wherever weapons sway in the direction you turn or the opposite";
TIP_PB_OFFSETSPEED = "How fast weapons raise and fall depending on your vertical velocity";
TIP_PB_OFFSETMAXRANGE = "Maximum Height weapons can fall";
TIP_PB_OFFSETDIRECTION = "Set Wherever the sprites are offset according to your vertical direction";

//Gore/debris options
TIP_PB_USEMODERNBLOOD = "Use modern blood impact effects.";
TIP_NASHGORE_BLOODMULT = "Blood amount multiplier. May cause performance issues at higher values.";
TIP_NASHGORE_SPRITEBLOOD = "Use decals or sprites for blood spots.";
TIP_NASHGORE_BLOODSPURT = "Enable blood spurts on corpses.";
TIP_PB_HIDEBLOODMIST = "Hide blood cloud effects.";
TIP_NASHGORE_GIBTYPE = "Gib effect type.";
TIP_NASHGORE_GIBAMOUNT = "Adjusts amount of gibs.";
TIP_NASHGORE_MAXGORE = "Maximum number of blood & gore objects to spawn.";
TIP_NASHGORE_MAXCASINGS = "Maximum number of spent casings to spawn.";
TIP_PB_CHEAPCASINGS = "To improve performance, casings will not react to the player and their surroundings";