//
//	base class for monsters weapon drops
//
const upgChance = 32; //12.5% chance
class PB_MonsterDropBase : inventory
{
	string		weaponDrop,		//the weapon to drop
				defaultDrop,	//upgrade to drop, if any (not necessarily an upgrade, can be a rare weapon)
				ammoDrop;		//the ammo to drop if weapon drops are disabled
	
	string 		weaponCvar;		//the cvar to check for the weapon (to avoid spawn it if its disabled)
	
	int			weaponFilter;
	
	property	drops:defaultDrop, weaponDrop, ammoDrop;
	property	filter:weaponCvar, weaponFilter;
	
	default
	{
		PB_MonsterDropBase.drops "", "", "";
		PB_MonsterDropBase.filter "", -1;
	}
	
	override void postbeginplay()
	{
		super.postbeginplay();
		switch(PB_WeaponDrops)
		{
			// PB_WeaponDrops 10 = spawn weapon drop (basically what vanilla doom does)
			case 0:
				if(weapondrop && isWeaponEnabled())
					spawndrop(weapondrop);
				else
					spawndrop(ammodrop);
				break;
				
			//	PB_WeaponDrops 2 = spawn default weapon (e.g. pistol/shotgun/minigun
			case 1:
				if(defaultdrop)
					spawndrop(defaultdrop);
				break;
				
			//spawn just ammo
			case 2:
				//console.printf("no weapons for you, just %s",ammodrop);
				spawndrop(ammodrop);
				break;
		}
		
	}
	
	bool isWeaponEnabled()
	{
		if(CVar.FindCVar(weaponCvar) && CVar.FindCVar(weaponCvar).GetInt() & weaponFilter)
			return false;
		return true;
	}
	
	void spawndrop(string drop)
	{
		if(!drop)
			return;
		
		let dp = spawn(drop,pos);
		if(dp)
		{
			dp.vel = vel;
			double dropfactor = (G_SkillPropertyFloat(SKILLP_DropAmmoFactor) == -1 ? 0.5:G_SkillPropertyFloat(SKILLP_DropAmmoFactor));
			if(dp is "weapon")
			{
				let wpdp = weapon(dp);
				if(wpdp)
					wpdp.ammogive1 = max(1,int(dropfactor * wpdp.ammogive1));
				return;
			}
			if(dp is "ammo")
			{
				let amdp = ammo(dp);
				if(amdp)
				{
					amdp.amount = max(1,int(dropfactor * amdp.amount)); //wouldnt make sense to receive 0 of something
				}
				return;
			}
			
		}
		
	}
	
	states
	{
		spawn:
			TNT1 A 1;
			stop;
	}
}


class PB_CarbineZombieDrop : PB_MonsterDropBase
{
	default
	{
		PB_MonsterDropBase.drops "PB_LowCalMag", "PB_Carbine", "PB_HighCalMag";
		PB_MonsterDropBase.filter "pb_chaingun_filter", DisablePB_Carbine;
	}
}

