class PB_UpgradeSpawnerT1 : PB_WeaponSpawner {}

class PB_UpgradeSpawnerT2 : PB_WeaponSpawner {}

class PB_UpgradeSpawnerT3 : PB_WeaponSpawner
{
	Default
	{
		PBRandomSpawner.Fallback "PB_UpgradeSpawnerT2";
		DropItem 'PB_SMG', 255, 1;
		DropItem 'PB_SGMagazine', 255, 1;
		DropItem 'PB_QuadSG', 255, 1;
		DropItem 'PB_HDMRUpgrade', 255, 1;
		DropItem 'PB_FlamethrowerUpgrade', 255, 1;
	}
	
	override bool HandleSpawnExceptions(name toSpawn)
	{
		if(toSpawn == "PB_SMG" && pb_pistol_filter & DisablePB_SMG)
			return false;
		if(toSpawn == "PB_SGMagazine" && pb_shotgun_filter & DisablePB_SGMagazine)
			return false;
		if(toSpawn == "PB_QuadSG" && pb_ssg_filter & DisablePB_QuadSG)
			return false;
		if(toSpawn == "PB_HDMRUpgrade" && pb_chaingun_filter & DisablePB_HDMRUpgrade)
			return false;
		if(toSpawn == "PB_FlamethrowerUpgrade" && pb_chainsaw_filter & DisablePB_FlamethrowerUpgrade)
			return false;
		return true;
	}
}

class PB_UpgradeSpawnerT4 : PB_WeaponSpawner
{
	Default
	{
		PBRandomSpawner.Fallback "PB_UpgradeSpawnerT3";
		DropItem 'PB_Deagle', 255, 1;
		DropItem 'PB_AutoshotgunUpgrade', 255, 1;
		DropItem 'PB_MinigunUpgrade', 255, 1;
		DropItem 'PB_M2Upgrade', 255, 1;
	}
	
	override bool HandleSpawnExceptions(name toSpawn)
	{
		if(toSpawn == "PB_Deagle" && pb_pistol_filter & DisablePB_Deagle)
			return false;
		if(toSpawn == "PB_AutoshotgunUpgrade" && pb_shotgun_filter & DisablePB_AutoshotgunUpgrade)
			return false;
		if(toSpawn == "PB_MinigunUpgrade" && pb_chaingun_filter & DisablePB_MinigunUpgrade)
			return false;
		if(toSpawn == "PB_M2Upgrade" && pb_plasmarifle_filter & DisablePB_M2Upgrade)
			return false;
		return true;
	}
}

Class UpgradeSpawner : PB_WeaponSpawner
{
	//$Title Random Upgrade Spawner
	//$Category Powerups
	//$Sprite UDBG=0
	default
	{
		Scale 0.2; //So the editor sprites isn't massive.
		DropItem 'PB_SMG', 255, 1;
		DropItem 'PB_SGMagazine', 255, 1;
		DropItem 'PB_QuadSG', 255, 1;
		DropItem 'PB_HDMRUpgrade', 255, 1;
		DropItem 'PB_FlamethrowerUpgrade', 255, 1;
		DropItem 'PB_Deagle', 255, 1;
		DropItem 'PB_AutoshotgunUpgrade', 255, 1;
		DropItem 'PB_MinigunUpgrade', 255, 1;
		DropItem 'PB_M2Upgrade', 255, 1;
	}
	
	override bool HandleSpawnExceptions(name toSpawn)
	{
		if(toSpawn == "PB_SMG" && pb_pistol_filter & DisablePB_SMG)
			return false;
		if(toSpawn == "PB_SGMagazine" && pb_shotgun_filter & DisablePB_SGMagazine)
			return false;
		if(toSpawn == "PB_QuadSG" && pb_ssg_filter & DisablePB_QuadSG)
			return false;
		if(toSpawn == "PB_HDMRUpgrade" && pb_chaingun_filter & DisablePB_HDMRUpgrade)
			return false;
		if(toSpawn == "PB_FlamethrowerUpgrade" && pb_chainsaw_filter & DisablePB_FlamethrowerUpgrade)
			return false;
		if(toSpawn == "PB_Deagle" && pb_pistol_filter & DisablePB_Deagle)
			return false;
		if(toSpawn == "PB_AutoshotgunUpgrade" && pb_shotgun_filter & DisablePB_AutoshotgunUpgrade)
			return false;
		if(toSpawn == "PB_MinigunUpgrade" && pb_chaingun_filter & DisablePB_MinigunUpgrade)
			return false;
		if(toSpawn == "PB_M2Upgrade" && pb_plasmarifle_filter & DisablePB_M2Upgrade)
			return false;
		return true;
	}
}
