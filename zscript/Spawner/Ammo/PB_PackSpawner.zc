Class PBBackpackSpawner : PB_SpawnerBase
{
	default
	{
		Species "medspawner";
	}
	States
	{
		Tier4:
			TNT1 A 0 PB_PackSpawnerSpawn("PB_PackSpawnerT4","PB_UpgradeSpawnerT4");
			Stop;
		Tier3:
			TNT1 A 0 PB_PackSpawnerSpawn("PB_PackSpawnerT3","PB_UpgradeSpawnerT3");
			Stop;
		Tier2:
			TNT1 A 0 PB_PackSpawnerSpawn("PB_PackSpawnerT2","PB_UpgradeSpawnerT2");
			Stop;
		Death:
			TNT1 A 0 A_Jump(64,"Tier2","Tier3","Tier4");
		Tier1:
			TNT1 A 0 PB_PackSpawnerSpawn("PB_PackSpawnerT1","PB_UpgradeSpawnerT1");
			Stop;
	}
	
	void PB_PackSpawnerSpawn(name spawner, name upgradespawner)
	{
		PB_SpawnerSpawn(spawner);
		if(random(0,1) == 1 && !pb_NoUpgrades)
			PB_SpawnerSpawn(upgradespawner);
	}
}

Class PB_PackSpawnerT1 : PB_AmmoSpawner
{
	Default
	{
		DropItem 'PB_Backpack', 255, 1;
	}
}

