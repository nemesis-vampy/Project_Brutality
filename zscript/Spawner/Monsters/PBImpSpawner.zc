{
	default
	{
		PBRandomSpawner.Fallback "PB_ImpSpawner_T3";
		PBRandomSpawner.SpawnOverride "pb_imp_override";
		dropitem "PB_DarkImpNether",255,1;
		dropitem "PB_DarkImpVoid",255,1;
		dropitem "PB_DarkImpNami",255,1;
		dropitem "PB_DarkImpST",255,1;
	}
	
	override bool HandleSpawnExceptions(name toSpawn)
	{
		if((toSpawn == "PB_DarkImpNether" || toSpawn == "PB_DarkImpVoid" || toSpawn == "PB_DarkImpNami" || toSpawn == "PB_DarkImpST") && pb_imp_filter & DisablePB_DarkImps)
			return false;
		return true;
	}
}