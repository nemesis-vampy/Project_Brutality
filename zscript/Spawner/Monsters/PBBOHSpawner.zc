Class PBBOHSpawner : PB_SpawnerBase
{
	States
	{
		Death:
		Tier4:
			TNT1 A 0 PB_SpawnerSpawn("PB_BaronSpawner_T4");
			Stop;
		Tier3:
			TNT1 A 0 PB_SpawnerSpawn("PB_BaronSpawner_T3");
			Stop;
		Tier2:
			TNT1 A 0 PB_SpawnerSpawn("PB_BaronSpawner_T2");
			Stop;
		Tier1:
			TNT1 A 0 PB_SpawnerSpawn("PB_BaronSpawner_T1");
			Stop;
	}
}

Class PB_BaronSpawner_T1 : PB_MonsterSpawner
{
	default
	{
		PBRandomSpawner.SpawnOverride "pb_baronofhell_override";
		dropitem "PB_Baron1",255,1;
	}
}

Class PB_BaronSpawner_T2 : PB_MonsterSpawner
{
	default
	{
		PBRandomSpawner.Fallback "PB_BaronSpawner_T1";
		PBRandomSpawner.SpawnOverride "pb_baronofhell_override";
		dropitem "PB_CyberBaron",255,1;
	}
	
	override bool HandleSpawnExceptions(name toSpawn)
	{
		if(toSpawn == "PB_CyberBaron" && pb_baronofhell_filter & DisablePB_CyberBaron)
			return false;
		return true;
	}
}

Class PB_BaronSpawner_T3 : PB_MonsterSpawner
{
	default
	{
		PBRandomSpawner.Fallback "PB_BaronSpawner_T2";
		PBRandomSpawner.SpawnOverride "pb_baronofhell_override";
		dropitem "PB_Infernus",255,1;
