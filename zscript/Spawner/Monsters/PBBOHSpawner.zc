}

Class PB_BaronSpawner_T4 : PB_MonsterSpawner
{
	default
	{
		PBRandomSpawner.Fallback "PB_BaronSpawner_T3";
		PBRandomSpawner.SpawnOverride "pb_baronofhell_override";
		dropitem "PB_Belphegor",255,1;
	}
	
	override bool HandleSpawnExceptions(name toSpawn)
	{
		if(toSpawn == "PB_Belphegor" && pb_baronofhell_filter & DisablePB_Belphegor)
