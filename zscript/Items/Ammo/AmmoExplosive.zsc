class PB_RocketAmmo : PB_Ammo
{
	Default
	{
		//$Category Project Brutality - Ammunition
		//$Sprite R0CKA0
		//Scale 0.45;
		Tag "Explosive Round";
		Inventory.Amount 1;
		Inventory.MaxAmount 50;
		Inventory.PickupSound "misc/rocket_PickUp";
		Ammo.BackpackAmount 1;
		Ammo.BackpackMaxAmount 100;
		PB_Ammo.ammotype "exp";
	}
}

