Actor PB_SMGBurstFire : Inventory
{
inventory.maxamount 1
}

Actor SMGBurstCounter : Inventory
{
	Inventory.MaxAmount 3
}

Actor SMGBurstCounterL : Inventory
{
	Inventory.MaxAmount 3
}

Actor UACSMGWasEmpty: Inventory
{
Inventory.maxamount 1
}

ACTOR RespectSMG : Inventory
{
Inventory.MaxAmount 1
}

ACTOR DualWieldingSMGs: Inventory
{
Inventory.MaxAmount 1
}

ACTOR SilencedSMG: Inventory
{
Inventory.MaxAmount 1
}

ACTOR SelectSilencedSMG: Inventory
{
Inventory.MaxAmount 1
}

ACTOR SMGAlternateADSFire: Inventory
{
Inventory.MaxAmount 1
}

Actor SelectDualWieldSMG : Inventory
{inventory.maxamount 1}
Actor SelectBurstFireSMG : SelectDualWieldSMG{}

ACTOR Laserdot: BulletPuff
{ 
	Decal "None"
	Mass 0
	Scale 0.10
	Radius 0
	Height 0
	VSpeed 0
	+NOINTERACTION
	+SQUAREPIXELS
	+NOGRAVITY
	+BLOODLESSIMPACT
	+ALWAYSPUFF
	+PUFFONACTORS
	+DONTSPLASH
	+FORCEXYBILLBOARD
	-ALLOWPARTICLES
	Renderstyle Add
	Alpha 0.75
	States
	{
	Melee:
	Spawn:
	Death:
	XDeath:
	Crash:
		TNT1 A 0 NoDelay A_SpawnItemEx("LaserAlertNearbyMonsters",0,0,0,0,0,0,0,288)
		LEYS R 1 BRIGHT
		Stop
	}
}

Actor LaserDotPerma : LaserDot
{
	States
	{
	Melee:
	Spawn:
		LEYS R 2 BRIGHT
		TNT1 A 0 A_SpawnItemEx("LaserAlertNearbyMonsters",0,0,0,0,0,0,0,288)
		Stop
	}
}
ACTOR LaserAlertNearbyMonsters : CustomInventory
{	
	Radius 600
	+DONTSPLASH
	+INVENTORY.QUIET
	Inventory.MaxAmount 1
	States
	{
	Spawn:
		TNT1 A 0 A_ALERTMONSTERS(750)
		TNT1 A 5
		Stop
	Pickup:
		TNT1 A 0 A_ALERTMONSTERS(750)
		TNT1 A 0 A_SetInventory("LaserAlertNearbyMonsters", 0)
		Stop
	}
}
ACTOR KeepLaserDeactivated : Inventory {}

ACTOR PB_SMG : PB_Weapon
{
	//$Category Project Brutality - Weapons
	//$Sprite ATFLA0
	SpawnID 9200
	Weapon.AmmoUse1 0
	Weapon.AmmoGive1 35
	Weapon.AmmoUse2 0
	Weapon.AmmoGive2 0
	Weapon.AmmoType1 "PB_LowCalMag"
	Weapon.AmmoType2 "SMGAmmo"
	weapon.slotpriority 0.75
	PB_WeaponBase.AmmoTypeLeft "LeftSMGAmmo"
	Inventory.MaxAmount 2
	Inventory.Amount 1
	+FLOORCLIP
	+DONTGIB
	Obituary "%o was shot down by %k's UAC-17 Compact Submachine Gun."
	Inventory.PickupSound "CLIPIN"
	Inventory.Pickupmessage "$PB_SMG_PICKUP"
	Tag "$PB_SMG_TAG"
	+WEAPON.NOAUTOAIM
	+WEAPON.NOALERT
	+WEAPON.NOAUTOFIRE
	Scale 0.4
	Inventory.AltHUDIcon "ATFLA0"
	PB_WeaponBase.RespectItem "RespectSMG"
	FloatBobStrength 0.5
	PB_WeaponBase.OffsetRecoilX 5.0
	PB_WeaponBase.OffsetRecoilY 2.5
	PB_WeaponBase.UsesWheel 1
	PB_WeaponBase.WheelInfo "PB_SMGWheel"
	PB_WeaponBase.TailPitch 1.2
	// PB_WeaponBase.BarrelAttachmentPoint (6, 0, 0), (6, 0, 0)
	+WEAPON.CHEATNOTWEAPON
	PB_WeaponBase.DualWieldToken "DualWieldingSMGs"
	States
	{
	Steady:
		TNT1 A 1
		Goto Ready
	Ready:
		TNT1 A 0
		TNT1 A 0 A_JumpIfInventory("GoFatality", 1, "Steady")
		TNT1 A 0 PB_RespectIfNeeded
	WeaponRespect:
		TNT1 A 0 {
			A_SetInventory("RespectSMG",1);
			A_SetInventory("PB_LockScreenTilt",1);
			A_PlaySoundEx("weapons/smg_raise", "Auto");
			A_SetCrosshair(-1);
		}
		A5F5 ABCDEFGHI 1 A_DoPBWeaponAction
		TNT1 A 0 A_StartSound("weapons/smg/screw/on", CHAN_AUTO, CHANF_DEFAULT, 0.2)
		A5F5 JJ 1 A_DoPBWeaponAction
		TNT1 A 0 A_StartSound("weapons/smg/screw_3", CHAN_AUTO)
		A5F5 LMNOJJ 1 A_DoPBWeaponAction
		TNT1 A 0 A_StartSound("weapons/smg/screw_2", CHAN_AUTO)
		A5F5 LMNOJJ 1 A_DoPBWeaponAction
		TNT1 A 0 A_StartSound("weapons/smg/screw_1", CHAN_AUTO)
		A5F5 JLMNOOOOO 1 A_DoPBWeaponAction
		TNT1 A 0 A_StartSound("weapons/smg/screw/off", CHAN_AUTO)
		A5F6 GHIJJJKLMNOPQRSTUVW 1 A_DoPBWeaponAction
		TNT1 A 0 A_StartSound("weapons/smg/respectmagup", CHAN_AUTO)
		A5F6 XYZ 1 A_DoPBWeaponAction
		A5F7 ABCDEFG 1 A_DoPBWeaponAction
		TNT1 A 0 A_StartSound("weapons/smg_out", CHAN_AUTO)
		A5F7 HIJJJJJO 1 A_DoPBWeaponAction
		TNT1 A 0 A_StartSound("weapons/smg/armup", CHAN_AUTO)
		A5F7 PQRSTU 1 A_DoPBWeaponAction
		TNT1 A 0 A_StartSound("weapons/smg_in", CHAN_AUTO)
		A5F7 VWXXX 1 A_DoPBWeaponAction
		A5F8 ABC 1 A_DoPBWeaponAction
		TNT1 A 0 A_StartSound("weapons/smg_lower", CHAN_AUTO)
		A5F8 DEFG 1 A_DoPBWeaponAction
		Goto Ready3
	
	SelectAnimation:
		TNT1 A 0 A_SetInventory("Zoomed",0)
		TNT1 A 0 A_JumpIfInventory("DualWieldingSMGs", 1, "SelectAnimationDualWield")
		TNT1 A 0 A_PlaySoundEx("weapons/smg_up", "Auto")
		TNT1 A 0 {
			if(CountInv("SilencedSMG") >= 1)
			{
				A_overlay(-2,"SelectSilencerOverlay");
			}
		}
		TNT1 A 0 A_JumpIf(PB_GetMagUnloaded, "SelectAnimationUnloaded")
		A1F1 ABCD 1
	Ready3:
		TNT1 A 0 A_SetInventory("KeepLaserDeactivated",0)
		// TNT1 A 0 A_JumpIfInventory("UACSMGWasEmpty", 1, "LoadChamber")
		TNT1 A 0 {
			A_SetRoll(0);
			A_SetInventory("PB_LockScreenTilt",0);
			PB_HandleCrosshair(67);
			}
		TNT1 A 0 A_JumpIfInventory("DualWieldingSMGs", 1, "ReadyDualWield")
	
	ReadyToFire:
		A1SU E 0
		A1S1 E 0
		A1U1 E 0 {
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "SilencerOverlay");
			}
		}
		A1F1 E 1 {
			PB_CoolDownBarrel;

			if(PB_GetMagUnloaded)
			{
				if(CountInv("SilencedSMG") >= 1)
				{
					A_SetWeaponSprite("A1SU");
				}
				else
				{
					A_SetWeaponSprite("A1U1");
				}
			}
			else if(CountInv("SilencedSMG") >= 1)
			{
				A_SetWeaponSprite("A1S1");
			}
			
			if (PressingFire() && PressingAltfire() && CountInv("SMGAmmo") > 0){
					return state("Fire");
			}
			if (PressingFire() && CountInv("SMGAmmo") > 0){
					return state("Fire");
			}
			return A_DoPBWeaponAction(WRF_ALLOWRELOAD);	
		}
		Loop
		
	Ready2:
		TNT1 A 0 {
			A_SetRoll(0);
			A_SetCrosshair(-1);
			A_SetInventory("PB_LockScreenTilt",0);
			}
	ReadyToFire2:
		A1F3 F 1 {
			if(CountInv("SilencedSMG") < 1)
			{
				PB_CoolDownBarrel(0, 0, 4.3);
			}
			//Updated code for far superior smooth gameplay
			if(GetCvar("pb_toggle_aim_hold")) {
				if(!PressingAltfire() || JustReleased(BT_ALTATTACK)){
					return state("Zoomout");
				}
				if (PressingFire() && PressingAltfire() && CountInv("SMGAmmo") > 0){
						return state("Fire2");
				}
				return A_DoPBWeaponAction(WRF_ALLOWRELOAD|WRF_NOSECONDARY);
			}
			else {
				if (PressingFire() && CountInv("SMGAmmo") > 0 ){
					return state("Fire2");
				}
				return A_DoPBWeaponAction(WRF_ALLOWRELOAD);
			}
			return state("");
		}
		Loop
	SelectAnimationUnloaded:
		A1F1 A 1
		A0F1 BCD 1
		Goto Ready3
	UnloadedReady:
		TNT1 A 0 A_JumpIfInventory("DualWieldingSMGs", 1, "UnloadedReadyDualWield")
		A1F1 Z 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD, PBWEAP_UNLOADED)
		Loop
	
	SelectAnimationDualWield:
		TNT1 A 0 A_PlaySoundEx("weapons/smg_up", "Auto")
		TNT1 A 4 {
			A_Overlay(10, "SwitchToDualWield_Left", false);
			A_Overlay(11, "SwitchToDualWield_Right", false);
			A_WeaponReady(WRF_NOFIRE);
		}
		TNT1 A 0 A_PlaySoundEx("weapons/smg_up", "Auto")
		Goto ReadyDualWield
	ReadyDualWield:
		TNT1 A 0 {
			A_SetRoll(0);
			A_SetInventory("PB_LockScreenTilt",0);
			if(CountInv("LeftSMGAmmo") < CountInv("SMGAmmo")){
				A_GiveInventory("DualFiring",1);
			}
// 			if(CountInv("PB_LowCalMag")>0){
// 				if(CountInv("LeftSMGAmmo")<=0){
// 					A_GiveInventory("DualFireReload",1);
// 				}
// 				if(CountInv("SMGAmmo")<=0){
// 					A_GiveInventory("DualFireReload",1);
// 				}
// 			}
			A_Overlay(10, "IdleLeft_Overlay", false);
			A_Overlay(11, "IdleRight_Overlay", false);
			}
	ReadyToFireDualWield:
		TNT1 A 1 {
			if(CountInv("PB_LowCalMag")>0){
				if(PB_GetChamberEmpty || PB_GetChamberEmpty(true)){
					if(PB_GetChamberEmpty && PB_GetChamberEmpty(true)){
						A_SetInventory("DualFireReload",2);
					}
					else{
						A_SetInventory("DualFireReload",1);
					}
				}
			}
			
			if(!PB_CanDualWield())
			{
					A_ClearOverlays(10,11);
					return state("StopDualWield");
			}
			
			return A_DoPBWeaponAction(WRF_ALLOWRELOAD|WRF_NOFIRE);
		}
		Loop
		
		
		
	IdleLeft_Overlay:
		A2FL A 1 {
			if(PB_GetMagUnloaded(true))
			{
				if(CountInv("SilencedSMG") >= 1)
				{
					A_SetWeaponFrame(3);
				}
				else
				{
					A_SetWeaponFrame(1);
					PB_CoolDownBarrel(15, 0, 0);
				}
			}
			else if(CountInv("SilencedSMG") >= 1)
			{
				A_SetWeaponFrame(2);
			}
			else
			{
				PB_CoolDownBarrel(15, 0, 0);
			}

			if(PB_GetChamberEmpty(true) && !PB_GetChamberEmpty){
				A_GiveInventory("DualFiring",1);
			}
			if((PressingAltFire() && CountInv("PB_SMGBurstFire") == 0 || JustPressed(BT_ALTATTACK)) && !A_IsFiringLeftWeapon() && GetCvar("SingleDualFire") == 2){
					if(!PB_GetChamberEmpty(true)){
						return state("FireLeft_Overlay");
					}
					else if(JustPressed(BT_ALTATTACK)) {
						A_PlaySoundEx("weapons/empty", "Auto");
						return state("");
					}
				}
			if(CountInv("DualFiring")==0 || (CountInv("DualFiring")==0 && CountInv("SMGAmmo")<=0) || GetCvar("SingleDualFire")==1){
				if((PressingFire() && CountInv("PB_SMGBurstFire") == 0 || JustPressed(BT_ATTACK)) && !A_IsFiringLeftWeapon() && GetCvar("SingleDualFire") < 2){
					if(!PB_GetChamberEmpty(true)){
						return state("FireLeft_Overlay");
					}
					else if(JustPressed(BT_ATTACK)) {
						A_PlaySoundEx("weapons/empty", "Auto");
						return state("");
					}
				}
			}
			return state("");
		}
		Loop
	IdleRight_Overlay:
		A2FR A 1 {
			if(PB_GetMagUnloaded)
			{
				if(CountInv("SilencedSMG") >= 1)
				{
					A_SetWeaponFrame(3);
				}
				else
				{
					A_SetWeaponFrame(1);
					PB_CoolDownBarrel(-15, 0, 0);
				}
			}
			else if(CountInv("SilencedSMG") >= 1)
			{
				A_SetWeaponFrame(2);
			}
			else
			{
				PB_CoolDownBarrel(-15, 0, 0);
			}
			if(!PB_GetChamberEmpty(true) && PB_GetChamberEmpty){
				A_TakeInventory("DualFiring",1);
			}
			if(CountInv("DualFiring")==1 || (CountInv("DualFiring")==1 && CountInv("LeftSMGAmmo")<=0)){
				if((PressingFire() && CountInv("PB_SMGBurstFire") == 0 || JustPressed(BT_ATTACK)) && !A_IsFiringLeftWeapon() && GetCvar("SingleDualFire")==0){
					if(!PB_GetChamberEmpty){
						return state("FireRight_Overlay");
					}
					else if(JustPressed(BT_ATTACK)) {
						A_PlaySoundEx("weapons/empty", "Auto");
						return state("");
					}
				}
			}
			if((PressingAltfire() && CountInv("PB_SMGBurstFire") == 0 || JustPressed(BT_ALTATTACK)) && !A_IsFiringRightWeapon() && GetCvar("SingleDualFire")==1){
				if(!PB_GetChamberEmpty) {
					return state("FireRight_Overlay");
				}
				else if(JustPressed(BT_ALTATTACK)) {
					A_PlaySoundEx("weapons/empty", "Auto");
					return state("");
				}
			}
			if((PressingFire() && CountInv("PB_SMGBurstFire") == 0 || JustPressed(BT_ATTACK)) && !A_IsFiringRightWeapon() && GetCvar("SingleDualFire")==2){
				if(!PB_GetChamberEmpty){
					return state("FireRight_Overlay");
				}
				else if(JustPressed(BT_ATTACK)) {
					A_PlaySoundEx("weapons/empty", "Auto");
					return state("");
				}
			}
			return state("");
		}
		Loop
	LeftFlash:
		A2FM B 1 Bright {
			if(CountInv("SilencedSMG") >= 1) {
				A_SetWeaponSpriteEx("A2SM");
			}
			A_GunFlash;
		}
		STOP
	FireLeft_Overlay:
		A2S1 DEF 0
		A2FU A 0
		A2SU A 0
		TNT1 A 0 A_SetInventory("SMGBurstCounterL",0)
	BurstLeft_Overlay:
		A2F1 D 1 {
			if(CountInv("SilencedSMG") >= 1) 
			{
				PB_DynamicTail("pistol_sup", "pistol_sup");
				A_StartSound("ZSpecOps/MGun", CHAN_Weapon, CHANF_DEFAULT, 0.15, ATTN_NORM, frandom(0.93, 1.07));
				A_StartSound("weapons/silencedsmg", CHAN_7, CHANF_DEFAULT, 1.0);
				PB_GunSmoke_FlashHider(-6, 0, 0);
                PB_MuzzleFlashEffects(-6, 0, 0, "FF9D2E", true, false);
				A_SetWeaponSpriteEx("A2S1");
				if(PB_GetMagUnloaded(true)){A_SetWeaponSpriteEx("A2SU");}
			}
			else
			{
				PB_IncrementHeat(1, true);
				PB_DynamicTail("smg", "smg");
				A_StartSound("ZSpecOps/MGun", CHAN_Weapon, CHANF_DEFAULT, 1, ATTN_NORM, frandom(0.93, 1.07));
				//A_StartSound("weapons/smg/overlay", CHAN_7, CHANF_DEFAULT, 1.0, ATTN_NORM, frandom(0.93, 1.07));
				PB_GunSmoke_Compensator(6,0,0); PB_MuzzleFlashEffects(6,0,0);
				A_AlertMonsters;
				A_FireCustomMissile("YellowFlareSpawn",0,0,-6,0);
				if(PB_GetMagUnloaded(true)){A_SetWeaponSpriteEx("A2FU");}
			}

			//A_FireBullets (0.1, 0.1, -1, 12, "HitPuff", FBF_NORANDOM,8192,"Tracer", -4, -8);
			PB_FireBullets("PB_9x19mmSubsonic", 1, 2, 0, 0, 2);
			//A_FireCustomMissile("GunFireSmoke", 0, 0, -4, 0, 0, 0);
			PB_SpawnCasing("EmptyBrassPistol",20,-10,33,Frandom(-3,3),Frandom(2,7),Frandom(1,2), true, true);
			A_FireCustomMissile("ShakeYourAssMinor", 0, 0, 0, 0);
			PB_LowAmmoSoundWarning("smg", "LeftSMGAmmo");
			PB_TakeAmmo("LeftSMGAmmo",1,1,0,true);
			A_ZoomFactor(0.985);
			A_Overlay(-5, "LeftFlash", true);
			A_OverlayFlags(-5,PSPF_RENDERSTYLE,true);
			A_OverlayRenderStyle(-5,STYLE_Add);
			PB_WeaponRecoil(-1.1,+0.76);
			A_GiveInventory("SMGBurstCounterL",1);
			}
		A2F1 E 1 {
			if(PB_GetMagUnloaded(true)){A_SetWeaponSpriteEx("A2FU");}
			if(CountInv("SilencedSMG") >= 1) 
			{
				A_SetWeaponSpriteEx("A2S1");
				if(PB_GetMagUnloaded(true)){A_SetWeaponSpriteEx("A2SU");}
			}
			A_ZoomFactor(0.99);
			if(CountInv("LeftSMGAmmo")<=0 || CountInv("SMGAmmo")>0 ){
				A_GiveInventory("DualFiring",1);
			}
			PB_WeaponRecoil(-1.1,+0.76);
			}
		A2F1 F 1 {
			if(PB_GetMagUnloaded){A_SetWeaponSpriteEx("A2FU");}
			if(CountInv("SilencedSMG") >= 1) 
			{
				A_SetWeaponSpriteEx("A2S1");
				if(PB_GetMagUnloaded(true)){A_SetWeaponSpriteEx("A2SU");}
			}
			A_ZoomFactor(1.0);
		}
		TNT1 A 0 A_JumpIf(CountInv("SMGBurstCounterL") < 3 && CountInv("PB_SMGBurstFire") == 1 && !PB_GetChamberEmpty(true), "BurstLeft_Overlay")
		TNT1 A 0 {
			if(CountInv("LeftSMGAmmo")<=0){
				A_GiveInventory("DualFireReload",1);
			}
			A_SetInventory("SMGBurstCounterL",0);
		}
		Goto IdleLeft_Overlay
	RightFlash:
		A2SM A 0
		A2FM A 1 Bright {
			if(CountInv("SilencedSMG") >= 1) {
				A_SetWeaponSpriteEx("A2SM");
			}
			A_GunFlash;
		}
		STOP
	FireRight_Overlay:
		A2S1 ABC 0
		TNT1 A 0 A_SetInventory("SMGBurstCounter",0)
	BurstRight_Overlay:
		A2F1 A 1 {
			if(CountInv("SilencedSMG") >= 1) 
			{
				PB_DynamicTail("pistol_sup", "pistol_sup");
				A_StartSound("ZSpecOps/MGun", CHAN_Weapon, CHANF_DEFAULT, 0.15, ATTN_NORM, frandom(0.93, 1.07));
				A_StartSound("weapons/silencedsmg", CHAN_7, CHANF_DEFAULT, 1.0);
				PB_GunSmoke_FlashHider(-6, 0, 0);
                PB_MuzzleFlashEffects(-6, 0, 0, "FF9D2E", true, false);
				A_SetWeaponSpriteEx("A2S1");
				if(PB_GetMagUnloaded){A_SetWeaponSpriteEx("A2SU");}
			}
			else
			{
				PB_IncrementHeat;
				PB_DynamicTail("smg", "smg");
				A_StartSound("ZSpecOps/MGun", CHAN_Weapon, CHANF_DEFAULT, 1, ATTN_NORM, frandom(0.93, 1.07));
				// A_StartSound("weapons/smg/overlay", CHAN_7, CHANF_DEFAULT, 1.0, ATTN_NORM, frandom(0.93, 1.07));
				PB_GunSmoke_Compensator(-6,0,0); PB_MuzzleFlashEffects(-6,0,0);
				A_AlertMonsters;
				A_FireCustomMissile("YellowFlareSpawn",0,0,6,0);
				if(PB_GetMagUnloaded){A_SetWeaponSpriteEx("A2FU");}
			}
			//A_FireBullets (0.1, 0.1, -1, 12, "HitPuff", FBF_NORANDOM,8192,"Tracer", -4, 8);
			PB_FireBullets("PB_9x19mmSubsonic", 1, 2, 0, 0, 2);
			//A_FireCustomMissile("GunFireSmoke", 0, 0, 4, 0, 0, 0);
			PB_SpawnCasing("EmptyBrassPistol",20,16,28,Frandom(-3,3),Frandom(2,7),Frandom(1,2), true, true);
			A_FireCustomMissile("ShakeYourAssMinor", 0, 0, 0, 0);
			PB_LowAmmoSoundWarning("smg");
			PB_TakeAmmo("SMGAmmo",1);
			A_ZoomFactor(0.985);
			A_Overlay(-6, "RightFlash", true);
			A_OverlayFlags(-6,PSPF_RENDERSTYLE,true);
			A_OverlayRenderStyle(-6,STYLE_Add);
			PB_WeaponRecoil(-1.1,-0.76);
			A_GiveInventory("SMGBurstCounter",1);
			}
		A2F1 B 1 {
			if(PB_GetMagUnloaded){A_SetWeaponSpriteEx("A2FU");}
			if(CountInv("SilencedSMG") >= 1) 
			{
				A_SetWeaponSpriteEx("A2S1");
				if(PB_GetMagUnloaded){A_SetWeaponSpriteEx("A2SU");}
			}
			A_ZoomFactor(0.99);
			if(CountInv("LeftSMGAmmo")>0 || CountInv("SMGAmmo")<=0 ){
				A_TakeInventory("DualFiring",1);
			}
			PB_WeaponRecoil(-1.1,-0.76);
		}
		A2F1 C 1 {
			if(PB_GetMagUnloaded){A_SetWeaponSpriteEx("A2FU");}
			if(CountInv("SilencedSMG") >= 1) 
			{
				A_SetWeaponSpriteEx("A2S1");
				if(PB_GetMagUnloaded){A_SetWeaponSpriteEx("A2SU");}
			}
			A_ZoomFactor(1.0);
		}
		TNT1 A 0 A_JumpIf(CountInv("SMGBurstCounter") < 3 && CountInv("PB_SMGBurstFire") == 1 && !PB_GetChamberEmpty, "BurstRight_Overlay")
		TNT1 A 0 {
			if(CountInv("SMGAmmo")<=0){
				A_GiveInventory("DualFireReload",1);
			}
			A_SetInventory("SMGBurstCounter",0);
		}
		Goto IdleRight_Overlay
		
		
		
	UnloadedReadyDualWield:
		A2F3 Z 1 A_DoPBWeaponAction(WRF_ALLOWRELOAD, PBWEAP_UNLOADED)
		Loop
		
	WheelCancel:
		TNT1 A 0 A_SetInventory("SelectBurstFireSMG",0)
		TNT1 A 0 A_SetInventory("SelectDualWieldSMG",0)
		TNT1 A 0 A_SetInventory("SelectSilencedSMG",0)
		Stop
		
	WeaponSpecial:
		TNT1 A 0 {
			A_SetInventory("GoWeaponSpecialAbility",0);
			A_SetInventory("Zoomed",0);
			A_SetInventory("ADSmode",0);
			A_SetInventory("PB_LockScreenTilt",1);
			//PB_HandleCrosshair(67);
			A_ZoomFactor(1.0);
			A_ClearOverlays(10,11);
			}
		TNT1 A 0 {
			if(CountInv("SelectBurstFireSMG") == 1) {	
				A_Overlay(-12, "WheelCancel");
				return state ("ToggleBurst");
				}
			if(CountInv("SelectDualWieldSMG") == 1) {
				A_Overlay(-12, "WheelCancel");
				return state ("DualHandler");
				}
			if(CountInv("SelectSilencedSMG") == 1) {
				A_Overlay(-12, "WheelCancel");
				return state ("SelectSilencedSMG");
				}
			return state("");
			}
			Goto Ready3
	SelectSilencedSMG:
		TNT1 A 0 {
			if(CountInv("SilencedSMG") == 1) 
			{	
				A_Print("$PB_PISTOL_SUPPRESSOFF");
				return state ("ScrewOffSilencer");
			}
			else
			{	
				A_Print("$PB_PISTOL_SUPPRESSON");
				return state ("ScrewOnSilencer");
			}
			return state("");
		}
		Goto Ready3
	ScrewOnSilencer:
		A4F3 ABCDEFGHIJKLMNOP 0
		A4F4 NOPQR 0
		TNT1 A 0 A_JumpIf(CountInv("DualWieldingSMGs") < 1, "ContinueScrewing")
		TNT1 A 4 {
			A_Overlay(10, "StopDualWield_Left", false);
			A_Overlay(11, "StopDualWield_Right", false);
		}
		A1F1 ABCD 1
	ContinueScrewing:
		TNT1 A 0 A_StartSound("weapons/smg/tilt", CHAN_AUTO)
		A0F3 ABCDEFG 1 {
			A_DoPBWeaponAction;
			if(PB_GetMagUnloaded)
			{
				A_SetWeaponSprite("A4F3");
			}
		}
		TNT1 A 0 A_StartSound("weapons/smg/armup", CHAN_AUTO)
		A0F3 HIKLMNO 1 {
			A_DoPBWeaponAction;
			if(PB_GetMagUnloaded)
			{
				A_SetWeaponSprite("A4F3");
			}
		}
		TNT1 A 0 A_StartSound("weapons/smg/screw/on", CHAN_AUTO)
		A0F3 PP 1 {
			A_DoPBWeaponAction;
			if(PB_GetMagUnloaded)
			{
				A_SetWeaponSprite("A4F3");
			}
		}
		TNT1 A 0 A_StartSound("weapons/smg/screw_1", CHAN_AUTO)
		A0F3 RSTUUPP 1 {
			A_DoPBWeaponAction;
			if(PB_GetMagUnloaded)
			{
				A_SetWeaponSprite("A4F3");
			}
		}
		TNT1 A 0 A_StartSound("weapons/smg/screw_2", CHAN_AUTO)
		A0F3 RSTUUPP 1 {
			A_DoPBWeaponAction;
			if(PB_GetMagUnloaded)
			{
				A_SetWeaponSprite("A4F3");
			}
		}
		TNT1 A 0 A_StartSound("weapons/smg/screw_3", CHAN_AUTO)
		A0F3 RSTUUUU 1 {
			A_DoPBWeaponAction;
			if(PB_GetMagUnloaded)
			{
				A_SetWeaponSprite("A4F3");
			}
		}
		TNT1 A 0 {
			A_StartSound("weapons/smg/screw/off", CHAN_AUTO, CHANF_DEFAULT, 0.2);
			A_SetInventory("SilencedSMG", 1);
		}
		A0F4 N 1 {
			A_DoPBWeaponAction;
