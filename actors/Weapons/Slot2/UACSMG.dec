		}
		A3F4 B 1
		A3F4 C 1 A_StartSound("weapons/smg/armup", CHAN_AUTO)
		A4FP DEFFF 1
		A4FP I 1 A_StartSound("weapons/smg/boltlock", CHAN_AUTO)
		A4FP J 3
		A4FP KLLLLOP 1
		Goto ReloadLeft2
	BoltPullDWSilencer:
		A3S4 ABCD 1
		ASF1 EEEE 1
		A4FS ABBBCDDDDEF 1
		Stop
	ReloadLeftGunOnly:
		TNT1 A 0 PB_CheckReload("","","","Ready3","Ready3",36,1,true)
		TNT1 A 3 {
			A_Overlay(10, "StopDualWield_Left", false);
			A_Overlay(11, "StopDualWield_Right", false);
		}
	ReloadLeftGun:
		TNT1 A 0 PB_CheckReload("ReloadLeftUnloaded","BoltPullLeft","RechamberLeft","Ready3","Ready3",36,1,true)
		TNT1 A 3
		TNT1 A 0 A_PlaySoundEx("weapons/smg_up", "Auto")
		TNT1 A 0 {
			if(CountInv("LeftSMGAmmo") < 1) {
				A_SetInventory("UACSMGWasEmpty", 1);
			}
			else {
				A_SetInventory("UACSMGWasEmpty", 0);
			}
		}
		TNT1 A 0 {
			if(CountInv("SilencedSMG") >= 1)
			{
				A_Overlay(-2, "ReloadDWSilencer");
			}
		}
		A3F4 ABCD 1
		TNT1 A 0 A_StartSound("weapons/rifle/magchange", CHAN_AUTO)
		A1F4 F 1 Offset(1, 32)
		A1F4 F 1 Offset(3, 32)
		A1F4 F 2 Offset(5, 32)
		A1F4 F 2 Offset(2, 32)
		A1F4 F 1 Offset(1, 32)
		TNT1 A 0 {
			A_StartSound("weapons/smg_out", CHAN_AUTO);
			PB_SetMagUnloaded(true,true);
			if(PB_GetMagEmpty(true)) {PB_SpawnCasing("SMGEmptyMagazine",30,0,16,1,2,-2,false);}
		}
		TNT1 A 0 A_WeaponOffset(0,32)
		A1F4 GGHIJ 1 A_SetRoll(roll-0.4, SPF_INTERPOLATE)
		A1F4 KLLLO 1 A_SetRoll(roll+0.4, SPF_INTERPOLATE)
		A1F4 OPQ 1
		A1F4 RRT 1 A_SetRoll(roll+0.5, SPF_INTERPOLATE)
		TNT1 A 0 A_PlaySoundEx("weapons/smg_in", "Auto")
		Goto ReloadLeftContinue
	ReloadLeftUnloaded:
		TNT1 A 0 A_JumpIf(PB_GetChamberEmpty(true),"BoltPullLeftUnloaded")
		TNT1 A 0 {
			if(CountInv("SilencedSMG") >= 1)
			{
				A_Overlay(-2, "ReloadUnloadedSilencer");
			}
			A_StartSound("weapons/smg/raise");
		}
		A4F1 UVW 1
		TNT1 A 0 A_StartSound("weapons/smg_in", CHAN_AUTO)
		A4F1 X 1
		Goto ReloadLeftContinue
	BoltPullSilencer2:
		ASFU ABCCC 1
		Stop
	BoltPullLeftUnloaded:
		A4FU A 1 {
			A_StartSound("weapons/smg/raise");
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "BoltPullSilencer");
			}
		}
		A4FU B 1
		A4FU C 1 A_StartSound("weapons/smg/armup", CHAN_AUTO)
		A4FU DEFFF 1
		A4FU I 1 A_StartSound("weapons/smg/boltlock", CHAN_AUTO)
		A4FU J 3
		A4FU KLLLL 1
		TNT1 A 0 {
			A_StartSound("weapons/smg/raise");
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "BoltPullSilencer2");
			}
		}
		A4FU OPRR 1
		TNT1 A 0 A_StartSound("weapons/smg_in", CHAN_AUTO)
		A4FU R 1
		TNT1 A 0 A_Overlay(2, "UnloadedBoltOverlay")
		Goto ReloadLeftContinue
	ReloadLeft2:
		//A1F4 AB 1
		A4F1 B 1 {
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "Reload2Silencer");
			}
		}
		A4F1 C 1 Offset(1, 32) A_StartSound("weapons/rifle/magchange", CHAN_AUTO)
		A4F1 C 1 Offset(3, 32)
		A4F1 C 2 Offset(5, 32)
		A4F1 C 2 Offset(2, 32)
		A4F1 C 1 Offset(1, 32)
		TNT1 A 0 {
			A_StartSound("weapons/smg_out", CHAN_AUTO);
			PB_SetMagUnloaded(true,true);
			if(PB_GetMagEmpty(true)) {PB_SpawnCasing("SMGEmptyMagazine",30,0,16,1,2,-2,false);}
		}
		TNT1 A 0 A_WeaponOffset(0,32)
		A4F1 DDEFG 1 A_SetRoll(roll-0.4, SPF_INTERPOLATE)
		A4F1 HIJKL 1 A_SetRoll(roll+0.4, SPF_INTERPOLATE)
		A4F1 LMN 1
		A4F1 OOP 1 A_SetRoll(roll+0.5, SPF_INTERPOLATE)
	ReloadLeftContinue:
		TNT1 A 0 {
			A_PlaySoundEx("Ironsights", "Auto");

			if(CountInv("UACSMGWasEmpty") >= 1) {
				A_Overlay(2, "EmptyBoltOverlay");
			}
		}
		TNTI A 0 {
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "ReloadContinueSilencer");
			}
		}
		A1F4 UVWXYZ 1 A_WeaponOffset(0,32,SPF_INTERPOLATE)
		TNT1 A 0 {
			if(PB_GetChamberEmpty(true)) {
				PB_AmmoIntoMag("LeftSMGAmmo","PB_LowCalMag",35,1);}
			else {
				PB_AmmoIntoMag("LeftSMGAmmo","PB_LowCalMag",36,1);}
			PB_SetMagUnloaded(false,true);
			PB_SetMagEmpty(false,true);
		}
		TNT1 A 0 A_JumpIf(PB_GetChamberEmpty(true),"LoadChamberLeft")
		TNT1 A 0 A_SetRoll(roll-0.5, SPF_INTERPOLATE)
		A1F5 ABCDE 1
		TNT1 A 0 {
			if(CountInv("SilencedSMG") >= 1)
			{
				A_Overlay(-2, "ReloadDWEndSilencer");
			}
		}	
		A3F4 DCBA 1
		Goto FinishInsertBullets
	RechamberLeft:
		TNT1 A 3
		TNT1 A 0 {
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "RechamberDWSilencer");
			}
		}
		A3F4 EFG 1
		A1F5 HGF 1
	LoadChamberLeft:
		HKSR ABCDEFGHIJKL 0
		HKSS ABCDE 0

		TNT1 A 0 A_PlaySoundEx("weapons/smg/raise", "Auto")
		A1F5 ABCDE 1
		HKSP ABCDEFG 1 {
			if(CountInv("SilencedSMG") >= 1)
			{
				A_SetWeaponSprite("HKSR");
			}
		}
		TNT1 A 0 A_StartSound("weapons/smg/armswing", CHAN_AUTO)
		HKSP HIJKL 1 {
			if(CountInv("SilencedSMG") >= 1)
			{
				A_SetWeaponSprite("HKSR");
			}
		}
		TNT1 A 0 {
			A_PlaySoundEx("weapons/smg_click", "Auto");
			PB_SetChamberEmpty(false,true);
		}
		HKSP MOPRSTUVWXYZ 1 {
			if(CountInv("SilencedSMG") >= 1)
			{
				A_SetWeaponSprite("HKSR");
			}
		}
		HKSQ AB 1 {
			if(CountInv("SilencedSMG") >= 1)
			{
				A_SetWeaponSprite("HKSS");
			}
		}
		HKSQ FGH 1 {
			if(CountInv("SilencedSMG") >= 1)
			{
				A_SetWeaponSprite("HKSS");
			}
		}
	FinishInsertBullets:
		TNT1 A 2
		TNT1 A 4 {
			A_Overlay(10, "SwitchToDualWield_Left", false);
			A_Overlay(11, "SwitchToDualWield_Right", false);
		}
		TNT1 A 0 PB_SetReloading(false)
		Goto Ready3
		
	Unload:
		TNT1 A 0 {
			A_ZoomFactor(1.0);
			A_SetCrosshair(-1);
			A_SetInventory("ADSmode",0);
			A_SetInventory("Zoomed",0);
			A_SetInventory("PB_LockScreenTilt",1);
			A_StartSound("weapons/smg/raise");
			A_ClearOverlays(10,11);
			}
		TNT1 A 0 A_JumpIf(A_CheckAkimbo(),"UnloadDualWield")
		A4FP I 0 {
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "BoltPullSilencer");
			}
		}
		A4FP AB 1
		TNT1 A 0 A_StartSound("weapons/smg/armup", CHAN_AUTO)
		A4FP CDEFFF 1
		TNT1 A 0 A_StartSound("weapons/smg/boltlock", CHAN_AUTO)
		A4FP IJJJ 1
		//TNT1 A 0 A_StartSound("weapons/smg/boltlock", CHAN_AUTO)
		A4FP KLLLLOP 1
		TNTI A 0 {
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "UnloadSilencer");
			}
		}
		//TNT1 A 0 A_StartSound("weapons/empty", CHAN_AUTO)
		A4F1 B 1
		A4F1 C 1 Offset(1, 32)
		A4F1 C 1 Offset(3, 32)
		A4F1 C 2 Offset(5, 32)
		A4F1 C 2 Offset(2, 32)
		TNT1 A 0 {
			A_StartSound("weapons/smg_out", CHAN_AUTO);
			PB_UnloadMag("SMGAmmo","PB_LowCalMag",1);
			PB_SetMagUnloaded(true);
			PB_SetChamberEmpty(true);
		}
		A4F1 C 1 Offset(1, 32)
		A4F1 GHIJKLMN 1
		TNT1 A 0 A_StartSound("weapons/smg/lower", CHAN_AUTO)
		A4F1 OQRST 1
	FInishUnload:
		TNT1 A 0 {
			PB_SetReloading(false);
			}
		Goto Ready3
	UnloadDualWield:
		TNT1 A 6 {
			A_Overlay(10, "StopDualWield_Left", false);
			A_Overlay(11, "StopDualWield_Right", false);
		}
		TNT1 A 0 A_JumpIf(PB_GetMagUnloaded,"UnloadLeft")
		TNT1 A 0 {
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "ReloadSilencer");
			}
		}
		TNT1 A 0 A_StartSound("weapons/smg/raise")
		TNT1 A 0 {
			if(CountInv("SilencedSMG") >= 1)
			{
				A_Overlay(-2, "ReloadDWSilencer");
			}
		}
		A3F4 A 1 {
			A_StartSound("weapons/smg/raise");
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "BoltPullDWSilencer");
			}
		}
		A3F4 B 1
		A3F4 C 1 A_StartSound("weapons/smg/armup", CHAN_AUTO)
		A4FP DEFFF 1
		A4FP I 1 A_StartSound("weapons/smg/boltlock", CHAN_AUTO)
		A4FP JJJ 1
		//TNT1 A 0 A_StartSound("weapons/smg/boltlock", CHAN_AUTO)
		A4FP KLLLLOP 1
		TNTI A 0 {
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "UnloadSilencer");
			}
		}
		//TNT1 A 0 A_StartSound("weapons/empty", CHAN_AUTO)
		A4F1 B 1
		A4F1 C 1 Offset(1, 32)
		A4F1 C 1 Offset(3, 32)
		A4F1 C 2 Offset(5, 32)
		A4F1 C 2 Offset(2, 32)
		TNT1 A 0 {
			A_StartSound("weapons/smg_out", CHAN_AUTO);
			PB_UnloadMag("SMGAmmo","PB_LowCalMag",1);
			PB_SetMagUnloaded(true);
			PB_SetChamberEmpty(true);
		}
		A4F1 C 1 Offset(1, 32)
		A4F1 GHIJKLMN 1
		TNT1 A 0 A_StartSound("weapons/smg/lower", CHAN_AUTO)
		A4F1 OQR 1
		TNT1 A 0 A_JumpIf(PB_GetMagUnloaded(true),"FInishUnloadDW")
		TNT1 A 2
	UnloadLeft:
		TNT1 A 0 {
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "ReloadSilencer");
			}
		}
		TNT1 A 0 A_StartSound("weapons/smg/raise")
		TNT1 A 0 {
