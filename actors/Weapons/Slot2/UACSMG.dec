//////////////////////////////////////////Unloading
		
	Spawn:
		VTFL A 0 NoDelay
		ATFL A 10 A_PbvpFramework("VTFL")
		"####" A 0 A_PbvpInterpolate()
		LOOP
		
	FlashKicking:
		TNT1 A 0 A_ClearOverlays(10,11)
		A4F7 ABCDEFGH 0
		A4Z7 ABCDEFGH 0
		A1U7 ABCDEFGH 0
		TNT1 A 0 A_JumpIfInventory("DualWieldingSMGs", 1, "FlashKickingDW")
		A1F7 ABCDEFGHFEDCBA 1 {
			A_DoPBWeaponAction;
			if(CountInv("SilencedSMG") >= 1)
			{
				if(PB_GetMagUnloaded)
				{
					A_SetWeaponSprite("A4Z7");
				}
				else
				{
					A_SetWeaponSprite("A4F7");
				}
			}
			else
			{
				if(PB_GetMagUnloaded)
				{
					A_SetWeaponSprite("A1U7");
				}
			}
		}
		Goto Ready3


	FlashPunching:
		TNT1 A 0 A_ClearOverlays(10,11)
		TNT1 A 0 A_JumpIfInventory("DualWieldingSMGs", 1, "FlashPunchingDW")
		TNT1 A 0 {
			if(CountInv("SilencedSMG") >= 1)
			{
				A_Overlay(-2, "FlashPunching_Silencer");
			}
		}
		A3F1 ABCDEFFFFEDCBA 1 {
			if(PB_GetMagUnloaded)
			{
				A_SetWeaponSpriteEx("A3U1");
			}
		}
		Goto Ready3
		
	FlashPunching_Silencer:
		A3S1 ABCDEFFFFEDCBA 1
		Stop
		
	FlashAirKicking:
		TNT1 A 0 A_ClearOverlays(10,11)
		TNT1 A 0 A_JumpIfInventory("DualWieldingSMGs", 1, "FlashAirKickingDW")
		A1F7 ABCDEFGHHGFEDCBA 1 {
			A_DoPBWeaponAction;
			if(CountInv("SilencedSMG") >= 1)
			{
				if(PB_GetMagUnloaded)
				{
