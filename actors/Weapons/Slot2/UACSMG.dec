	ToggleBurst:
		TNT1 A 0 {
				if(CountInv("PB_SMGBurstFire")){
				A_SetInventory("PB_SMGBurstFire",0); 
				A_Print("$PB_FIREMODE_FULL");
				}
				else{
				A_SetInventory("PB_SMGBurstFire",1); 
				A_Print("$PB_FIREMODE_BURST");
				}
			}
		TNT1 A 0 A_JumpIf(A_CheckAkimbo(),"ToggleBurst_Dual")
		TNT1 A 0 {
			if(CountInv("SilencedSMG") >= 1)
			{
				A_Overlay(-2, "FlashPunching_Silencer");
			}
		}
		A3F1 ABCDEFF 1 {
			if(PB_GetMagUnloaded)
			{
				A_SetWeaponSpriteEx("A3U1");
			}
		}
		TNT1 A 0 A_StartSound("LIGHTON",CHAN_AUTO)
		A3F1 FFEDCBA 1 {
			if(PB_GetMagUnloaded)
			{
				A_SetWeaponSpriteEx("A3U1");
			}
		}
		Goto Ready3
	ToggleBurst_Dual:
		TNT1 A 0 {
			if(CountInv("SilencedSMG") >= 1)
			{
				A_Overlay(8, "FlashKickingDW_Left_Silencer");
				A_Overlay(9, "FlashKickingDW_Right_Silencer");
			}
			if(PB_GetMagUnloaded(true)) {A_Overlay(10, "FlashKickingDW_Left_Unloaded");}
			else { A_Overlay(10, "FlashKickingDW_Left");}
			if(PB_GetMagUnloaded) {A_Overlay(11, "FlashKickingDW_Right_Unloaded");}
			else {A_Overlay(11, "FlashKickingDW_Right");}
		}
		TNT1 AAAAAAA 1
		TNT1 A 0 A_StartSound("LIGHTON",CHAN_AUTO)
		TNT1 AAAAAAAA 1
		Goto Ready3
		
	
	DualHandler:
		TNT1 A 0 A_JumpIfInventory("DualWieldingSMGs", 1, "StopDualWield")
		TNT1 A 0 A_JumpIfInventory("PB_SMG", 2,"SwitchToDualWield")
		TNT1 A 0 A_Print("You need two submachine guns to dual wield!")
		Goto Ready3
	SwitchToDualWield:
		TNT1 A 0 {
			A_SetInventory("DualWieldingSMGs", 1);
			A_SetAkimbo(true);
			A_PlaySoundEx("weapons/smg_up", "Auto");
			if(CountInv("SilencedSMG") >= 1)
			{
				A_Overlay(-2, "SwitchToDualWield_Silencer");
			}
		}
		A0F2 A 0 A_JumpIf(PB_GetMagUnloaded,2) //Load the unloaded frames into memory
		A1F2 A 0
		"####" ABCDE 1
		TNT1 A 0 A_Overlay(10, "SwitchToDualWield_Left")
		A2FR A 4 {
			if(PB_GetMagUnloaded)
			{
				if(CountInv("SilencedSMG") >= 1)
				{
					A_SetWeaponFrame(3);
				}
				else
				{
					A_SetWeaponFrame(1);
				}
			}
			else if(CountInv("SilencedSMG") >= 1)
			{
				A_SetWeaponFrame(2);
			}
		}
		Goto ReadyDualWield
	SwitchToDualWield_Left:
		TNT1 A 0 {
			if(CountInv("SilencedSMG") >= 1)
			{
				A_Overlay(-2, "SwitchToDualWield_Left_Silencer");
			}
		}
		A2L3 D 1
		A2L3 C 1 {
			if(PB_GetMagUnloaded(true)) { A_SetWeaponFrame(6); }
		}
		A2L3 B 1 {
			if(PB_GetMagUnloaded(true)) { A_SetWeaponFrame(5); }
		}
		A2L3 A 1 {
			if(PB_GetMagUnloaded(true)) { A_SetWeaponFrame(4); }
		}
		Stop
	SwitchToDualWield_Right:
		TNT1 A 0 {
			if(CountInv("SilencedSMG") >= 1)
			{
				A_Overlay(-3, "SwitchToDualWield_Right_Silencer");
			}
		}
		A2R3 DC 1
		A2R3 B 1 {
			if(PB_GetMagUnloaded) { A_SetWeaponFrame(5); }
		}
		A2R3 A 1 {
			if(PB_GetMagUnloaded) { A_SetWeaponFrame(4); }
		}
		Stop
	SwitchToDualWield_Left_Silencer:
		A2LS DCBA 1
		Stop
	SwitchToDualWield_Right_Silencer:
		A2RS DCBA 1
		Stop
	SwitchToDualWield_Silencer:
		A2FS ABCDE 1
		Stop
	StopDualWield:
		TNT1 A 0 {
			A_SetInventory("DualWieldingSMGs", 0);
			A_SetAkimbo(false);
			A_PlaySoundEx("weapons/smg_up", "Auto");
			A_Overlay(10, "StopDualWield_Left");
			}
			A2FR A 4 {
				if(PB_GetMagUnloaded)
				{
					if(CountInv("SilencedSMG") >= 1)
					{
						A_SetWeaponFrame(3);
					}
					else
					{
						A_SetWeaponFrame(1);
					}
				}
				else if(CountInv("SilencedSMG") >= 1)
				{
					A_SetWeaponFrame(2);
				}
			}
			TNT1 A 0 {
				if(CountInv("SilencedSMG") >= 1)
				{
					A_Overlay(-2, "StopDualWield_Silencer");
				}
				}
		A0F2 A 0 A_JumpIf(PB_GetMagUnloaded,2) //Load the unloaded frames into memory
		A1F2 A 0
		"####" EDCBA 1
		Goto Ready3

	StopDualWield_Left:
		TNT1 A 0 {
			if(CountInv("SilencedSMG") >= 1)
			{
				A_Overlay(-2, "StopDualWield_Left_Silencer");
			}
		}
		
		A2L3 A 1 {
			if(PB_GetMagUnloaded(true)) { A_SetWeaponFrame(4); }
		}
		A2L3 B 1 {
			if(PB_GetMagUnloaded(true)) { A_SetWeaponFrame(5); }
		}
		A2L3 C 1 {
			if(PB_GetMagUnloaded(true)) { A_SetWeaponFrame(6); }
		}
		A2L3 D 1
		Stop
	StopDualWield_Right:
		TNT1 A 0 {
			if(CountInv("SilencedSMG") >= 1)
			{
				A_Overlay(-3, "StopDualWield_Right_Silencer");
			}
		}
		
		A2R3 A 1 {
			if(PB_GetMagUnloaded) { A_SetWeaponFrame(5); }
		}
		A2R3 B 1 {
			if(PB_GetMagUnloaded) { A_SetWeaponFrame(6); }
		}
		A2R3 CD 1
		Stop
	StopDualWield_Left_Silencer:
		A2LS ABCD 1
		Stop
	StopDualWield_Right_Silencer:
		A2RS ABCD 1
		Stop
	StopDualWield_Silencer:
		A2FS EDCBA 1
		Stop
	
	Deselect:
		TNT1 A 0 {
			A_DestroyLaserPuff();
			A_WeaponOffset(0,32);
			A_SetRoll(0);
			A_SetInventory("PB_LockScreenTilt",0);
			A_ClearOverlays(10,11);
			A_ClearOverlays(2,2);
			A_ClearOverlays(-2,-2);
		}
		TNT1 A 0 A_SetInventory("Unloading",0)
		TNT1 A 0 A_SetInventory("Zoomed",0)
		TNT1 A 0 A_SetInventory("ADSmode",0)
		TNT1 A 0 A_Overlay(-9, "Null")
		TNT1 A 0 A_ZoomFactor(1.0)
		TNT1 A 0 A_JumpIfInventory("DualWieldingSMGs", 1, "DeselectDualWield")
		TNT1 A 0 {
			if(CountInv("SilencedSMG") >= 1)
			{
				A_overlay(-2,"DeselectSilencerOverlay");
			}
		}
		TNT1 A 0 A_JumpIf(PB_GetMagUnloaded,"DeselectUnloaded")
		A1F1 DCBA 1
		TNT1 A 0 A_DestroyLaserPuff
		TNT1 A 0 A_Lower(120)	//its 2077, we have parameters now! 
		Wait
	DeselectDWUnloaded:
		A0F2 IHGF 1 A_Lower
		A0F2 EDC 1
		TNT1 A 0 A_Lower(120)
		Wait
	DeselectUnloaded:
		A0F1 DCB 1
		A1F1 A 1
		TNT1 A 0 A_Lower(120)
		Wait
	DeselectDualWield:
		TNT1 A 4 {
			A_Overlay(10, "StopDualWield_Left", false);
			A_Overlay(11, "StopDualWield_Right", false);
		}
		TNT1 A 0 A_DestroyLaserPuff
		TNT1 A 0 A_Lower(120)
		Wait

	Select:
		TNT1 A 0 {
			A_WeaponOffset(0,32);
			A_SetRoll(0);
			A_SetInventory("PB_LockScreenTilt",0);
			A_ClearOverlays(10,11);
		}
		TNT1 A 0 PB_TakeIfUpgrade("PB_Pistol") //A_TakeInventory("PB_Carbine",2)
		
		Goto SelectFirstPersonLegs
		SelectContinue:
		TNT1 A 0
		TNT1 A 0 PB_WeapTokenSwitch("UACSMGSelected")
		TNT1 AAAAAAAAAAAAAAAAAA 0 A_Raise
		TNT1 AAAAAAAA 1 A_Raise
		Wait
		
	Fire:
		TNT1 A 0 A_JumpIfInventory ("DualWieldingSMGs", 1, "ReadyDualWield")
		TNT1 A 0 {
			A_SetInventory("SMGBurstCounter",0);
			A_WeaponOffset(0,32);
			A_SetRoll(0);
			A_SetInventory("PB_LockScreenTilt",0);
			PB_HandleCrosshair(67);
			}
	Burst:
		TNT1 A 0 PB_JumpIfNoAmmo
		TNT1 A 0 A_JumpIfInventory("Zoomed",1,"Fire2")
		TNT1 A 0 A_Jump(256, "Flash_Variant1", "Flash_Variant2", "Flash_Variant3", "Flash_Variant4", "Flash_Variant5")
	ActualFire:
		"####" "#" 1 {
			if(CountInv("SilencedSMG") >= 1) 
			{
				PB_DynamicTail("pistol_sup", "pistol_sup");
				A_StartSound("ZSpecOps/MGun", CHAN_Weapon, CHANF_DEFAULT, 0.15, ATTN_NORM, frandom(0.93, 1.07));
				A_StartSound("weapons/silencedsmg", CHAN_7, CHANF_DEFAULT, 1.0);
				PB_GunSmoke_FlashHider(0, 0, 0);
                PB_MuzzleFlashEffects(0, 0, 4, "FF9D2E", true, false);
				A_SetWeaponSprite("A1S1");
				if(PB_GetMagUnloaded) {A_SetWeaponSprite("A1S2");}
			}
			else
			{
				PB_IncrementHeat;
				PB_DynamicTail("smg", "smg");
				A_StartSound("ZSpecOps/MGun", CHAN_Weapon, CHANF_DEFAULT, 1, ATTN_NORM, frandom(0.93, 1.07));
				// A_StartSound("weapons/smg/overlay", CHAN_7, CHANF_DEFAULT, 1.0, ATTN_NORM, frandom(0.93, 1.07));
				PB_GunSmoke_Compensator(0, 0, 0); PB_MuzzleFlashEffects(0, 0, 0);
				A_AlertMonsters;
				A_FireCustomMissile("YellowFlareSpawn",0,0,0,0);
				if(PB_GetMagUnloaded) {A_SetWeaponSprite("A1F2");}
			}

			PB_FireOffset;
			//A_FireBullets (0.1, 0.1, -1, 12, "HitPuff", FBF_NORANDOM,8192,"Tracer", -2,0);
			PB_FireBullets("PB_9x19mmSubsonic", 1, 2, 0, 0, 2);
			//A_FireCustomMissile("GunFireSmoke", 0, 0, 0, 0, 0, 0);
			A_FireCustomMissile("ShakeYourAssMinor", 0, 0, 0, 0);
			PB_SpawnCasing("EmptyBrassPistol",21,3,30,Frandom(-3,3),Frandom(2,7),Frandom(1,2), true, true);
			PB_LowAmmoSoundWarning("smg");
			PB_TakeAmmo("SMGAmmo",1);
			A_ZoomFactor(0.985);
			PB_WeaponRecoil(-0.24,+0.22);
			A_GiveInventory("SMGBurstCounter",1);
		}
		A1F1 G 1 {
			A_ZoomFactor(0.99);
			PB_WeaponRecoil(-0.24,+0.22);
		
			if(PB_GetMagUnloaded) {A_SetWeaponSprite("A1F2");}
			if(CountInv("SilencedSMG") >= 1) {
				A_SetWeaponSprite("A1S1");
				if(PB_GetMagUnloaded) {A_SetWeaponSprite("A1S2");}
			}
		}
		A1F1 H 1 {
			A_ZoomFactor(1.0);
		
			if(PB_GetMagUnloaded) {A_SetWeaponSprite("A1F2");}
			if(CountInv("SilencedSMG") >= 1) {
				A_SetWeaponSprite("A1S1");
				if(PB_GetMagUnloaded) {A_SetWeaponSprite("A1F2");}
			}
		}
		TNT1 A 0 A_JumpIf(CountInv("SMGBurstCounter") < 3 && CountInv("PB_SMGBurstFire") == 1, "Burst")
		A1F1 EEEE 1 {
			A_SetInventory("SMGBurstCounter",0);
			PB_CoolDownBarrel;
			if(PB_GetMagUnloaded)
			{
				if(CountInv("SilencedSMG") >= 1)
				{
					A_SetWeaponSprite("A1SU");
				}
				else
				{
					A_SetWeaponSprite("A1U1");
				}
			}
			else if(CountInv("SilencedSMG") >= 1)
			{
				A_SetWeaponSprite("A1S1");
			}
			if(PressingAltfire()) {return state("ZoomIn");}
			if(PressingFire() && CountInv("PB_SMGBurstFire") == 0 || JustPressed(BT_ATTACK)) {return state("Fire");}
			return A_DoPBWeaponAction(WRF_ALLOWRELOAD|WRF_NOFIRE);
		}
		TNT1 A 0 PB_ReFire("Fire")
		Goto Ready3
	Flash_Variant1:
		A1F1 F 0 {
			if(CountInv("SilencedSMG") >= 1) {
				A_SetWeaponSprite("A1S1");
			}
			A_Overlay(-5, "GunFlash1", true);
			A_OverlayFlags(-5,PSPF_RENDERSTYLE,true);
			A_OverlayRenderStyle(-5,STYLE_Add);
		}
		Goto ActualFire
	Flash_Variant2:
		A1F1 I 0 {
			if(CountInv("SilencedSMG") >= 1) {
				A_SetWeaponSprite("A1S1");
			}
			A_Overlay(-5, "GunFlash2", true);
			A_OverlayFlags(-5,PSPF_RENDERSTYLE,true);
			A_OverlayRenderStyle(-5,STYLE_Add);
		}
		Goto ActualFire
	Flash_Variant3:
		A1F1 J 0 {
			if(CountInv("SilencedSMG") >= 1) {
				A_SetWeaponSprite("A1S1");
			}
			A_Overlay(-5, "GunFlash3", true);
			A_OverlayFlags(-5,PSPF_RENDERSTYLE,true);
			A_OverlayRenderStyle(-5,STYLE_Add);
		}
		Goto ActualFire
	Flash_Variant4:
		A1F1 K 0 {
			if(CountInv("SilencedSMG") >= 1) {
				A_SetWeaponSprite("A1S1");
			}
			A_Overlay(-5, "GunFlash4", true);
			A_OverlayFlags(-5,PSPF_RENDERSTYLE,true);
			A_OverlayRenderStyle(-5,STYLE_Add);
