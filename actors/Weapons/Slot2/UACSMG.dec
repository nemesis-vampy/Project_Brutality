	Flash_Variant5:
		A1F1 L 0 {
			if(CountInv("SilencedSMG") >= 1) {
				A_SetWeaponSprite("A1S1");
			}
			A_Overlay(-5, "GunFlash5", true);
			A_OverlayFlags(-5,PSPF_RENDERSTYLE,true);
			A_OverlayRenderStyle(-5,STYLE_Add);
		}
		Goto ActualFire
	GunFlash1:
		A1SM F 0
		A1FM F 1 Bright {
			if(CountInv("SilencedSMG") >= 1) {
				A_SetWeaponSpriteEx("A1SM");
			}
			A_GunFlash;
		}
		STOP
	GunFlash2:
		A1FM I 1 Bright {
			if(CountInv("SilencedSMG") >= 1) {
				A_SetWeaponSpriteEx("A1SM");
			}
			A_GunFlash;
		}
		STOP
	GunFlash3:
		A1FM J 1 Bright {
			if(CountInv("SilencedSMG") >= 1) {
				A_SetWeaponSpriteEx("A1SM");
			}
			A_GunFlash;
		}
		STOP
	GunFlash4:
		A1FM K 1 Bright {
			if(CountInv("SilencedSMG") >= 1) {
				A_SetWeaponSpriteEx("A1SM");
			}
			A_GunFlash;
		}
		STOP
	GunFlash5:
		A1FM L 1 Bright {
			if(CountInv("SilencedSMG") >= 1) {
				A_SetWeaponSpriteEx("A1SM");
			}
			A_GunFlash;
		}
		STOP

	CacheFire:
		A1S1 A 0
		A1S2 A 0
		A1F6 A 0
		A1S3 A 0
		A1F2 A 0
		A3U1 A 0
		Stop
	
	SelectSilencerOverlay:
		A0S1 ABCD 1
		stop
	DeselectSilencerOverlay:
		A0S1 DCBA 1
		stop

	AimSilencerOverlay:
		A1S3 ABC 1
		Stop
	AimOutSilencerOverlay:
		A1S3 CBA 1
		Stop
	
		Fire2:
		TNT1 A 0 {
			A_SetInventory("SMGBurstCounter",0);
			A_WeaponOffset(0,32);
			A_SetCrosshair(-1);
		}
	Burst2:
		TNT1 A 0 PB_JumpIfNoAmmo
		A1F3 G 1 {
			if(CountInv("SilencedSMG") >= 1) 
			{
				PB_DynamicTail("pistol_sup", "pistol_sup");
				A_StartSound("ZSpecOps/MGun", CHAN_Weapon, CHANF_DEFAULT, 0.15, ATTN_NORM, frandom(0.93, 1.07));
				A_StartSound("weapons/silencedsmg", CHAN_7, CHANF_DEFAULT, 1.0);
				PB_GunSmoke_FlashHider(0, 0, 4.3);
                PB_MuzzleFlashEffects(0, 6, 4.3, "FF9D2E", true, false);
				A_SetWeaponSprite("A1S3");
			}
			else
			{
				PB_IncrementHeat;
				PB_DynamicTail("smg", "smg");
				A_StartSound("ZSpecOps/MGun", CHAN_Weapon, CHANF_DEFAULT, 1, ATTN_NORM, frandom(0.93, 1.07));
				// A_StartSound("weapons/smg/overlay", CHAN_7, CHANF_DEFAULT, 1.0, ATTN_NORM, frandom(0.93, 1.07));
				PB_GunSmoke_Compensator(0,0,4.3); PB_MuzzleFlashEffects(0,0,4.3);
				A_AlertMonsters;
				A_FireCustomMissile("YellowFlareSpawn",0,0,0,0);
			}

			PB_FireOffset;
			//A_FireBullets (0.1, 0.1, -1, 12, "HitPuff", FBF_NORANDOM,8192,"Tracer", -2,0);
			PB_FireBullets("PB_9x19mmSubsonic", 1, 2, 0, 0, 2);
			//A_FireCustomMissile("GunFireSmoke", 0, 0, 0, 3, 0, 0);
			A_FireCustomMissile("ShakeYourAssMinor", 0, 0, 0, 0);
			PB_SpawnCasing("EmptyBrassPistol",19,3,35,Frandom(-3,3),Frandom(2,7),Frandom(1,2), true, true);
			PB_LowAmmoSoundWarning("smg");
			PB_TakeAmmo("SMGAmmo",1);
			A_ZoomFactor(1.24);
			PB_WeaponRecoil(-0.2,+0.18);
			A_SetInventory("SMGAlternateADSFire", randompick(0, 1));
			A_GiveInventory("SMGBurstCounter",1);
			A_GunFlash;
			}
		A1F3 H 1 {
			A_ZoomFactor(1.245);
			PB_WeaponRecoil(-0.2,+0.18);

			if(CountInv("SMGAlternateADSFire") >= 1)
			{
				A_SetWeaponSprite("A1F6");
				A_SetRoll(roll - 0.5);
			}
			else
			{
				A_SetRoll(roll - 0.5);
			}
		}
		A1F3 I 1 {
			A_ZoomFactor(1.25);
			if(CountInv("SMGAlternateADSFire") >= 1)
			{
				A_SetWeaponSprite("A1F6");
				A_SetRoll(roll + 0.5);
			}
			else
			{
				A_SetRoll(roll - 0.5);
			}
		}
		TNT1 A 0 A_JumpIf(CountInv("SMGBurstCounter") < 3 && CountInv("PB_SMGBurstFire") == 1, "Burst2")
		A1F3 FFFFFFFF 1 {
			A_SetInventory("SMGAlternateADSFire", 0);
			A_SetInventory("SMGBurstCounter",0);
			PB_CoolDownBarrel;
			if(GetCvar("pb_toggle_aim_hold")) {
				if(!PressingAltfire()){
					return state("Zoomout");
				}
		
				if ((CountInv("PB_SMGBurstFire") == 0 && PressingFire() || JustPressed(BT_ATTACK)) && PressingAltfire()){
						return state("Fire2");
				}
			}
			else {
				if(PressingAltfire()){
					return state("Zoomout");
				}
				
				if (CountInv("PB_SMGBurstFire") == 0 && PressingFire() || JustPressed(BT_ATTACK)){
						return state("Fire2");
				}
			}
			return A_DoPBWeaponAction(WRF_ALLOWRELOAD|WRF_NOFIRE);
		}
		TNT1 A 0 A_JumpIf(PressingFire(), "Fire2")
		Goto Ready2
	
	AltFire:
		TNT1 A 0 A_JumpIfInventory ("DualWieldingSMGs", 1, "ReadyDualWield")
		TNT1 A 0 {
			A_WeaponOffset(0,32);
			A_SetRoll(0);
			PB_HandleCrosshair(67);
			A_SetInventory("PB_LockScreenTilt",0);
		}
		TNT1 A 0 A_JumpIf(PB_GetMagUnloaded, "Ready3")
		TNT1 A 0 A_PlaySound("IronSights", 0)
		TNT1 A 0 A_JumpIfInventory("Zoomed",1,"Zoomout")
	ZoomIn:
		TNT1 A 0 {
			A_SetCrosshair(-1);
			A_SetInventory("Zoomed",1);
			A_ZoomFactor(1.25);
			A_SetInventory("ADSmode",1);
		}
		TNTI A 0 {
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "AimSilencerOverlay");
			}
		}
		A1F3 ABCDE 1
		Goto Ready2
		
	Zoomout:
		TNT1 A 0 {
			A_SetInventory("ADSmode",0);
			A_SetInventory("Zoomed",0);
			A_ZoomFactor(1.0);
			}
		A1F3 ED 1
		TNTI A 0 {
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "AimOutSilencerOverlay");
			}
		}
		A1F3 CBA 1
		TNT1 A 0 PB_HandleCrosshair(67)
		Goto Ready3
		
	Reload:
		TNT1 A 0 A_JumpIf(A_CheckAkimbo(), "ReloadDualWield")
		TNT1 A 0 PB_CheckReload("ReloadUnloaded","BoltPull","Rechamber","Ready3","Ready3",36,1)
		TNT1 A 0 {
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "ReloadSilencer");
			}
		}
		TNT1 A 0 A_StartSound("weapons/smg/raise")
		A1F4 ABCD 1
		TNT1 A 0 A_StartSound("weapons/rifle/magchange", CHAN_AUTO)
		A1F4 F 1 A_WeaponOffset(1, 32)
		A1F4 F 1 A_WeaponOffset(3, 32)
		A1F4 F 2 A_WeaponOffset(5, 32)
		A1F4 F 2 A_WeaponOffset(2, 32)
		A1F4 F 1 A_WeaponOffset(1, 32)
		TNT1 A 0 {
			A_StartSound("weapons/smg_out", CHAN_AUTO);
			PB_SetMagUnloaded(true);
			if(PB_GetMagEmpty) {PB_SpawnCasing("SMGEmptyMagazine",30,0,16,1,2,-2,false);}
		}
		TNT1 A 0 A_WeaponOffset(0,32)
		A1F4 GGHIJ 1 A_SetRoll(roll-0.4, SPF_INTERPOLATE)
		A1F4 KLLLO 1 A_SetRoll(roll+0.4, SPF_INTERPOLATE)
		A1F4 OPQ 1
		A1F4 RR 1 A_SetRoll(roll+0.5, SPF_INTERPOLATE)
		TNT1 A 0 A_PlaySoundEx("weapons/smg_in", "Auto")
		A1F4 T 1 A_SetRoll(roll+0.5, SPF_INTERPOLATE)
		Goto ReloadContinue
		
	BoltPull:
		A4FP A 1 {
			A_StartSound("weapons/smg/raise");
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "BoltPullSilencer");
			}
		}
		A4FP B 1
		A4FP C 1 A_StartSound("weapons/smg/armup", CHAN_AUTO)
		A4FP DEFFF 1
		A4FP I 1 A_StartSound("weapons/smg/boltlock", CHAN_AUTO)
		A4FP J 3
		A4FP KLLLLOP 1
		Goto Reload2
	BoltPullSilencer:
		ASF1 ABCDEEEE 1
		A4FS ABBBCDDDDEF 1
		Stop
	Reload2:
		A4F1 B 1 {
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "Reload2Silencer");
			}
		}
		A4F1 C 1 {
			A_WeaponOffset(1, 32);
			A_StartSound("weapons/rifle/magchange", CHAN_AUTO);
		}
		A4F1 C 1 A_WeaponOffset(3, 32)
		A4F1 C 2 A_WeaponOffset(5, 32)
		A4F1 C 2 A_WeaponOffset(2, 32)
		A4F1 C 1 A_WeaponOffset(1, 32)
		TNT1 A 0 {
			A_StartSound("weapons/smg_out", CHAN_AUTO);
			PB_SetMagUnloaded(true);
			if(PB_GetMagEmpty) {PB_SpawnCasing("SMGEmptyMagazine",30,0,16,1,2,-2,false);}
		}
		TNT1 A 0 A_WeaponOffset(0,32)
		A4F1 DDEFG 1 A_SetRoll(roll-0.4, SPF_INTERPOLATE)
		A4F1 HIJKL 1 A_SetRoll(roll+0.4, SPF_INTERPOLATE)
		A4F1 LMN 1
		A4F1 OO 1 A_SetRoll(roll+0.5, SPF_INTERPOLATE)
		TNT1 A 0 A_StartSound("weapons/smg_in", CHAN_AUTO)
		A4F1 P 1 A_SetRoll(roll+0.5, SPF_INTERPOLATE)
	ReloadContinue:
		TNT1 A 0 {
			if(PB_GetChamberEmpty) {
				A_Overlay(2, "EmptyBoltOverlay");
			}
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "ReloadContinueSilencer");
			}
			A_StartSound("weapons/smg/tilt");
		}
		A1F4 UVWXY 1 A_WeaponOffset(0,32,SPF_INTERPOLATE)
		A1F4 Z 1 A_SetRoll(roll-0.5, SPF_INTERPOLATE)
		TNT1 A 0 {
			if(PB_GetChamberEmpty) {
				PB_AmmoIntoMag("SMGAmmo","PB_LowCalMag",35,1);}
			else {
				PB_AmmoIntoMag("SMGAmmo","PB_LowCalMag",36,1);}
			PB_SetMagUnloaded(false);
			PB_SetMagEmpty(false);
		}
		TNT1 A 0 A_StartSound("weapons/smg/raise", CHAN_AUTO)
		A1F5 ABCDE 1
		TNT1 A 0 A_JumpIf(PB_GetChamberEmpty,"LoadChamber")
		TNT1 A 0 {
			if(CountInv("SilencedSMG") >= 1 && !PB_GetChamberEmpty) {
				A_Overlay(-2, "InsertBullets2Silencer");
			}
		}
		A1F5 F 1 A_JumpIf(A_CheckAkimbo(), "InsertBulletsRight")
		TNT1 A 0 A_StartSound("weapons/smg/lower")
		A1F5 GHIJKL 1 A_SetRoll(roll-0.5, SPF_INTERPOLATE)
		TNT1 A 0 PB_SetReloading(false)
		Goto Ready3
	RechamberSilencer:
		ASF2 FFEDCBA 1
		Stop
	Rechamber:
		TNT1 A 0 {
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "RechamberSilencer");
			}
		}
		A1F5 LKJIHGF 1
	LoadChamber:
		HKSR A 0
		HKSS A 0
		HKSP ABCDEFG 1 {
			if(CountInv("SilencedSMG") >= 1) {A_SetWeaponSprite("HKSR");}
		}
		TNT1 A 0 A_StartSound("weapons/smg/armswing", CHAN_AUTO)
		HKSP HIJKL 1 {
			if(CountInv("SilencedSMG") >= 1) {A_SetWeaponSprite("HKSR");}
		}
		TNT1 A 0 {
			A_StartSound("weapons/smg_click", CHAN_AUTO);
			PB_SetChamberEmpty(false);
		}
		HKSP MOPRSTUVWXYZ 1 {
			if(CountInv("SilencedSMG") >= 1) {A_SetWeaponSprite("HKSR");}
		}
		HKSQ AB 1 {
			if(CountInv("SilencedSMG") >= 1) {A_SetWeaponSprite("HKSS");}
		}
		TNT1 A 0 A_JumpIf(A_CheckAkimbo(), "InsertBulletsRight")
		HKSQ CDE 1 {
			if(CountInv("SilencedSMG") >= 1) {A_SetWeaponSprite("HKSS");}
		}
		Goto Ready3
	ReloadUnloaded:
		TNT1 A 0 A_JumpIf(PB_GetChamberEmpty,"BoltPullUnloaded")
		TNT1 A 0 {
			if(CountInv("SilencedSMG") >= 1)
			{
				A_Overlay(-2, "ReloadUnloadedSilencer");
			}
			A_StartSound("weapons/smg/raise");
		}
		A4F1 UVW 1
		TNT1 A 0 A_StartSound("weapons/smg_in", CHAN_AUTO)
		A4F1 X 1
		TNT1 A 0 A_Overlay(2, "UnloadedBoltOverlay")
		Goto ReloadContinue
	BoltPullUnloaded:
		A4FU A 1 {
			A_StartSound("weapons/smg/raise");
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "BoltPullSilencer");
			}
		}
		A4FU B 1
		A4FU C 1 A_StartSound("weapons/smg/armup", CHAN_AUTO)
		A4FU DEFFF 1
		A4FU I 1 A_StartSound("weapons/smg/boltlock", CHAN_AUTO)
		A4FU J 3
		A4FU KLLLL 1
		TNT1 A 0 {
			A_StartSound("weapons/smg/raise");
			if(CountInv("SilencedSMG") >= 1) {
				A_Overlay(-2, "BoltPullSilencer2");
			}
		}
		A4FU OPRR 1
		TNT1 A 0 A_StartSound("weapons/smg_in", CHAN_AUTO)
		A4FU R 1
		Goto ReloadContinue

