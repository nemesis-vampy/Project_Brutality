		TNT1 A 0 A_StartSound("weapons/smg/raise", CHAN_AUTO)
		A0F4 OPQR 1 {
			A_DoPBWeaponAction;
			if(PB_GetMagUnloaded)
			{
				A_SetWeaponSprite("A4F4");
			}
		}
		TNT1 A 0 A_JumpIfInventory("DualWieldingSMGs", 1, "SwitchToDualWield")
