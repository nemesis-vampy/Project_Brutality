				if(CountInv("HDMRSniperMode") == 1) {
					A_SetWeaponSprite("H6F4");
				}
				else {
					A_SetWeaponSprite("H6F3");
				}
			}
		}
		TNT1 A 0 PB_SetReloading(false)
		Goto Ready3
	UnloadLeftOnly:
		R2F7 ABCD 1 {
			if(CountInv("DMRUpgraded") == 1) {A_SetWeaponSprite("H6F5");}
			if(CountInv("HDMRSniperMode") == 1) {A_SetWeaponSprite("H6F6");}
		}
	UnloadLeft:
		TNT1 A 3
		R8F1 EFGHIJKLMNO 1 {
			if (CountInv("DMRUpgraded") == 1) {
				if(CountInv("HDMRSniperMode") == 1) {
					A_SetWeaponSprite("H31F");
				}
				else {
					A_SetWeaponSprite("H11F");
				}
			}
		}
		TNT1 A 0 {
			A_PlaySoundEx("weapons/rifle/magout", "Auto");
			if(CountInv("DMRUpgraded") == 0) {
				if(PB_GetMagEmpty(true)) {PB_SpawnCasing("EmptyDMRMag",38,-20,7,frandom(0, 3.5),frandom(7.2, 3.3),frandom(3,7));}
				PB_UnloadMag("LeftDMRAmmo","PB_HighCalMag",1);
			}
			else if(CountInv("HDMRSniperMode") == 0) {
				if(PB_GetMagEmpty(true)) {PB_SpawnCasing("EmptyHDMRMag",38,-20,7,frandom(0, 3.5),frandom(7.2, 3.3),frandom(3,7));}
				PB_UnloadMag("LeftDMRAmmo","PB_HighCalMag",1);
			}
			else if(CountInv("HDMRSniperMode") == 1) {
				if(PB_GetMagEmpty(true)) {PB_SpawnCasing("EmptyHDMRMag_Sniper",38,-12,7,frandom(0, 3.5),frandom(7.2, 3.3),frandom(3,7));}
				PB_UnloadMag("LeftDMRAmmo","PB_HighCalMag",2);
			}
			PB_SetMagUnloaded(true,true);
			PB_SetChamberEmpty(true,true);
			PB_SetMagEmpty(true,true);
		}
		R8F1 PQRSTUVWXYZ 1 {
			if (CountInv("DMRUpgraded") == 1) {
				if(CountInv("HDMRSniperMode") == 1) {
					A_SetWeaponSprite("H31F");
				}
				else {
					A_SetWeaponSprite("H11F");
				}
			}
		}
		TNT1 A 0 PB_SetReloading(false)
		Goto Ready3

	Spawn:
		VIFL A 0 NoDelay 
		RIFL A 10 A_PBVPFramework("VIFL")
		"####" "#" 0 A_PbvpInterpolate()
		LOOP

			
	FlashKicking:
		TNT1 A 0 A_ClearOverlays(10,11)
		TNT1 A 0 A_JumpIfInventory("DualWieldingDMRs", 1, "FlashKicking2")
