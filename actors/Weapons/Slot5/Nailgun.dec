				A_StartSound("weapons/nailgun/inspect4", CHAN_AUTO);
				if(PB_GetChamberEmpty) {
					PB_AmmoIntoMag("PB_NailgunAmmo","PB_HighCalMag",5,20);
				}
				else {
					PB_AmmoIntoMag("PB_NailgunAmmo","PB_HighCalMag",6,20);
				}
				PB_SetMagUnloaded(false);
				PB_SetMagEmpty(false);
			}
			J4N3 GHIJK 1 {
				if(PB_GetChamberEmpty) {A_SetWeaponSprite("J4N7");}
			}
			TNT1 A 0 A_JumpIf(!PB_GetChamberEmpty,"Ready3")
		LoadChamberJavelin:
			J4N7 LMNOPQRS 1
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect2", CHAN_AUTO)
			J4N7 TUVW 1
			TNT1 A 0 A_StartSound("weapons/nailgun/loadjavelin", CHAN_AUTO)
			J4N7 XYZ 1
			J4N8 ABCDEFGH 1
			TNT1 A 0 PB_SetChamberEmpty(false)
			J4N8 IJKLM 1
			Goto Ready3
		ReloadUnloadedJavelin:
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect1", CHAN_AUTO)
			J6N0 A 0
			J6N1 ABCDEFG 1 {
				if(PB_GetChamberEmpty) {A_SetWeaponSprite("J6N0");}
			}
			Goto ContinueReloadJavelin
		Unload:
			TNT1 A 0 A_JumpIfInventory("JavelinMode", 1, "UnloadJavelin")
			N3N0 ABCDEFG 1 {
				A_SetRoll(roll-0.2, SPF_INTERPOLATE);
				if(PB_GetMagEmpty) {A_SetWeaponSprite("N0NA");}
			}
			N3N0 HI 1 {
				if(PB_GetMagEmpty) {A_SetWeaponSprite("N0NA");}
			}
			N3N0 KLMNOPQ 1 {
				A_SetRoll(roll-0.1, SPF_INTERPOLATE);
				if(PB_GetMagEmpty) {A_SetWeaponSprite("N0NA");}
			}
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect4", CHAN_AUTO)
			N3N0 RSTUVWXY 1 {
				A_SetRoll(roll+0.1, SPF_INTERPOLATE);
				if(PB_GetMagEmpty) {A_SetWeaponSprite("N0NA");}
			}
			N3N0 Z 1 {
				if(PB_GetMagEmpty) {A_SetWeaponSprite("N0NA");}
			}
			N3N1 ABCDE 1 {
				A_SetRoll(roll+0.2, SPF_INTERPOLATE);
				if(PB_GetMagEmpty) {A_SetWeaponSprite("N0NB");}
			}
			TNT1 A 0 {
				A_StartSound("weapons/nailgun/inspect8", CHAN_AUTO);
				if(PB_GetMagEmpty) {PB_SpawnCasing("EmptyNailgunDrum", 12, 2.5, 10.25,frandom(2,5),frandom(1,3),frandom(2,4));}
				PB_UnloadMag("PB_NailgunAmmo","PB_HighCalMag",1,1,0,0,"PB_HighCalBox");
				PB_SetMagUnloaded(true);
				PB_SetChamberEmpty(true);
			}
			N3N1 FG 1 {
				A_SetRoll(roll+0.2, SPF_INTERPOLATE);
				if(PB_GetMagEmpty) {A_SetWeaponSprite("N0NB");}
			}
			N3N1 H 1 {
				if(PB_GetMagEmpty) {A_SetWeaponSprite("N0NB");}
			}
			N3N1 IJ 1 {
				A_SetRoll(roll+0.2, SPF_INTERPOLATE);
				if(PB_GetMagEmpty) {A_SetWeaponSprite("N0NB");}
			}
			N3N8 HGFEDCBA 1
			TNT1 A 0 PB_SetReloading(false)
			Goto Ready3
			
		UnloadJavelin:
			TNT1 A 0 A_JumpIf(PB_GetMagUnloaded, "JavelinReadyUnloaded")
			TNT1 A 0 A_JumpIfInventory("PB_NailgunAmmo",1,1)
			Goto Ready3
			TNT1 A 0 A_StartSound("weapons/nailgun/up", CHAN_AUTO)
			J3N6 ABCDEFG 1
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect2", CHAN_AUTO)
			J3N6 HIJKLMNO 1 
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect3", CHAN_AUTO)
			J3N6 PQRSTUV 1
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect2", CHAN_AUTO)
			J3N6 WXYZ 1
			J3N7 ABCDEFGHI 1 
			TNT1 A 0 A_StartSound("weapons/nailgun/up", CHAN_AUTO)
			J3N7 JKLMNOPQRSTUVWXY 1 
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect4", CHAN_AUTO)
			J3N7 Z 1
			J3N8 ABCDEFGHIJ 1 
			TNT1 A 0 {
				A_StartSound("weapons/nailgun/inspect5", CHAN_AUTO);
				if(PB_GetMagEmpty) {PB_SpawnCasing("EmptyNailgunDrum", 12, 2.5, 10.25,frandom(2,5),frandom(1,3),frandom(2,4));}
				PB_UnloadMag("PB_NailgunAmmo","PB_HighCalMag",20,1,0,0,"PB_HighCalBox");
				PB_SetMagUnloaded(true);
				PB_SetChamberEmpty(true);
			}
			J3N8 KLMNOPQRSTUVWXYZ 1
			J3N9 ABCDE 1 
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect4", CHAN_AUTO)
			J3N9 FGHIJ 1
			Goto Ready3

		FlashPunching:
			TNT1 A 0 A_JumpIfInventory ("GrabbedBarrel", 1, "FlashBarrelPunching")
			TNT1 A 0 A_JumpIfInventory ("GrabbedFlameBarrel", 1, "FlashBarrelPunching")
			TNT1 A 0 A_JumpIfInventory ("GrabbedIceBarrel", 1, "FlashBarrelPunching")
			TNT1 A 0 A_Overlay(3,"Cooling",true)
			TNT1 A 0 A_JumpIfInventory("JavelinMode", 1, "FlashPunchingJavelin")
			N4N0 ABCDEFGHIJKLMN 1
			N1N0 D 1
			Stop

		FlashKicking:
			TNT1 A 0 A_JumpIfInventory ("GrabbedBarrel", 1, "FlashBarrelKicking")
			TNT1 A 0 A_JumpIfInventory ("GrabbedFlameBarrel", 1, "FlashBarrelKicking")
			TNT1 A 0 A_JumpIfInventory ("GrabbedIceBarrel", 1, "FlashBarrelKicking")
			TNT1 A 0 A_JumpIfInventory("JavelinMode", 1, "FlashKickingJavelin")
			N4N0 ABCDEFGHIJKLMN 1
			N1N0 D 1
			Goto Ready3
			
		FlashPunchingJavelin:
			J5N0 ABCDEFGHIJKLMN 1
			J0N0 D 1
			Stop
		
		FlashKickingJavelin:
			J5N0 ABCDEFGHIJKLMN 1
			J0N0 D 1
			Goto Ready3
		
		FlashAirKicking:
			TNT1 A 0 A_JumpIfInventory ("GrabbedBarrel", 1, "FlashBarrelAirKicking")
			TNT1 A 0 A_JumpIfInventory ("GrabbedFlameBarrel", 1, "FlashBarrelAirKicking")
			TNT1 A 0 A_JumpIfInventory ("GrabbedIceBarrel", 1, "FlashBarrelAirKicking")	
			TNT1 A 0 A_JumpIfInventory("JavelinMode", 1, "FlashKickingJavelin")
			N4N0 ABCDEFGHIJKLMN 1
			N1N0 DDD 1
			Goto Ready3
			
		FlashAirKickingJavelin:
			J5N0 ABCDEFGHIJKLMN 1
			J0N0 DDD 1
			Goto Ready3
			
		FlashSlideKicking:
			TNT1 A 0 A_JumpIfInventory ("GrabbedBarrel", 1, "FlashBarrelSlideKicking")
			TNT1 A 0 A_JumpIfInventory ("GrabbedFlameBarrel", 1, "FlashBarrelSlideKicking")
			TNT1 A 0 A_JumpIfInventory ("GrabbedIceBarrel", 1, "FlashBarrelSlideKicking")
			TNT1 A 0 A_JumpIfInventory("JavelinMode", 1, "FlashSlideKickingJavelin")
			N4N1 ABCDEFGHIJKLMMMNOPQRSTUVWX 1
			Goto Ready3
		FlashSlideKickingJavelin:
			J5N1 ABCDEFGHIJKLMMMNOPQRSTUVWX 1
			Goto Ready3
			
		FlashSlideKickingStop:
			TNT1 A 0 A_JumpIfInventory ("GrabbedBarrel", 1, "FlashBarrelSlideKickingStop")
			TNT1 A 0 A_JumpIfInventory ("GrabbedFlameBarrel", 1, "FlashBarrelSlideKickingStop")
			TNT1 A 0 A_JumpIfInventory ("GrabbedIceBarrel", 1, "FlashBarrelSlideKickingStop")
			TNT1 A 0 A_JumpIfInventory("JavelinMode", 1, "FlashSlideKickingStopJavelin")
			N4N1 RSTUVWX 1 
			Goto Ready3
		FlashSlideKickingStopJavelin:
			J5N1 RSTUVWX 1 
			Goto Ready3
	}
}

Actor JavelinProjectile
{
	Projectile
	Radius 6
	Height 6
	Speed 75
	Damage 60
	Damagetype "Blast"
	Scale 1.2
	+BloodSplatter
	+Ripper
	-NOGRAVITY
	+MISSILE
	SeeSound ""
	DeathSound "Weapons/NailHit"
	Decal BulletChip
	Gravity 0.14
	
	VAR INT USER_LIFETIME;
	
	States
	{
		Spawn:
			NAIL B 1 BRIGHT 
			Loop
		Crash:
		Death:
			
			TNT1 A 0 { 
				A_ChangeFlag("NOGRAVITY",1);
				A_SpawnItem("HitPuff");
				A_Stop;
			}
			TNT1 AAAA 0 A_CustomMissile ("HitSpark", 2, 0, frandom(0,1)*frandom (0, 360), 2, frandom(0,1)*frandom (30, 360))
			TNT1 AAAA 0 A_CustomMissile ("HitSpark22", 2, 0, frandom(0,1)*frandom (0, 360), 2, frandom(0,1)*frandom (30, 360))
			TNT1 AAAA 0 A_CustomMissile ("HitSpark23", 2, 0, frandom(0,1)*frandom (0, 360), 2, frandom(0,1)*frandom (30, 360))
// 			NAIL B 70
// 			NAIL BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB 1 A_FadeOut(0.02)
// 			Stop
		Hanging:
			NAIL B 10
			TNT1 A 0 {
				USER_LIFETIME--;
				A_JumpIf(USER_LIFETIME <= 0, "Fade");
				return A_CheckBlock("Hanging", 0, 0, (RADIUS / 2) + 1);
			}
		Drop:
			TNT1 A 0 A_ChangeFlag(NOINTERACTION, false)
			TNT1 A 0 A_ChangeFlag(NOGRAVITY, false)
			TNT1 A 0 A_ChangeFlag(THRUACTORS, true)
		Fade:
			NAIL B 1 A_FadeOut(0.2, FTF_CLAMP| FTF_REMOVE)
			Wait
		Disappear:
			TNT1 A 0 A_SpawnItem("HitPuff")
			Stop
		XDeath:
			NLPJ B 0 A_PlaySound("Weapons/NailHitBleed")
			Stop
	}
}

Actor JavelinProjectile_Hot : JavelinProjectile
{
	Speed 100
	Damage 90
	
	States 
	{
		Spawn:
			NAIL A 1 BRIGHT 
			Loop
		Crash:
		Death:
			TNT1 A 0 A_ChangeFlag(MOVEWITHSECTOR, true)
			TNT1 A 0 A_SetUserVar("USER_LIFETIME", 7)
			TNT1 A 0 { 
				A_ChangeFlag("NOGRAVITY",1);
				A_SpawnItem("HitPuff");
				A_Stop;
			}
			TNT1 AAAA 0 A_CustomMissile ("HitSpark", 2, 0, frandom(0,1)*frandom (0, 360), 2, frandom(0,1)*frandom (30, 360))
			TNT1 AAAA 0 A_CustomMissile ("HitSpark22", 2, 0, frandom(0,1)*frandom (0, 360), 2, frandom(0,1)*frandom (30, 360))
			TNT1 AAAA 0 A_CustomMissile ("HitSpark23", 2, 0, frandom(0,1)*frandom (0, 360), 2, frandom(0,1)*frandom (30, 360))
// 			NAIL B 70
// 			NAIL BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB 1 A_FadeOut(0.02)
// 			Stop
		Hanging:
			NAIL B 10
			TNT1 A 0 {
				USER_LIFETIME--;
				A_JumpIf(USER_LIFETIME <= 0, "Fade");
				return A_CheckBlock("Hanging", 0, 0, (RADIUS / 2) + 1);
			}
		Drop:
			TNT1 A 0 A_ChangeFlag(NOINTERACTION, false)
			TNT1 A 0 A_ChangeFlag(NOGRAVITY, false)
			TNT1 A 0 A_ChangeFlag(THRUACTORS, true)
		Fade:
			NAIL B 1 A_FadeOut(0.2, FTF_CLAMP| FTF_REMOVE)
			Wait
	}
}


//Original Decorate code by TheShooter7, Mechadon from realm667 Nail Gun
Actor EnemyNail
{
	Projectile
	Radius 2
	Height 2
	Speed 40
	Damage 2
	Damagetype "Nailgun"
	Scale 0.7
	+BloodSplatter
	+MISSILE
	SeeSound ""
	DeathSound "Weapons/NailHit"
	Decal BulletChip
	
	VAR INT USER_LIFETIME;
	
	States
	{
		Spawn:
			NLPJ A 1 A_PlaySound("Weapons/NailFlight", CHAN_BODY,1.0,True)
			NLPJ A 1 //A_SpawnItemEx("NailBlur", 0, 0, 0, 1, 0, 0, 180, 128)
			Wait
		Crash:
		Death:
			TNT1 A 0 A_ChangeFlag(MOVEWITHSECTOR, true)
			TNT1 A 0 A_SetUserVar("USER_LIFETIME", 10)
			TNT1 A 0 A_StopSound(CHAN_BODY)
			TNT1 A 0 A_SpawnItem("HitPuff")
		Hanging:
			NLPJ A 20
			TNT1 A 0 {
				USER_LIFETIME--;
				A_JumpIf(USER_LIFETIME <= 0, "Fade");
				return A_CheckBlock("Hanging", 0, 0, (RADIUS / 2) + 1);
			}
		Drop:
			TNT1 A 0 A_ChangeFlag(NOINTERACTION, false)
			TNT1 A 0 A_ChangeFlag(NOGRAVITY, false)
			TNT1 A 0 A_ChangeFlag(THRUACTORS, true)
		Fade:
			NLPJ A 1 A_FadeOut(0.2, FTF_CLAMP| FTF_REMOVE)
			Wait
		XDeath:
			TNT1 A 0 A_StopSound(CHAN_BODY)
			NLPJ B 0 A_PlaySound("Weapons/NailHitBleed")
			Stop
	}
}