Actor NailgunFiringAnimation: Inventory
{
Inventory.maxamount 1
}

Actor JavelinMode: Inventory
{
Inventory.maxamount 1
}

Actor OverHeating: Inventory
{
Inventory.maxamount 140
}

Actor RespectNailgun : Inventory
{
Inventory.MaxAmount 1
}

ACTOR PB_NailgunAmmo : PB_WeaponAmmo
{
	Inventory.Amount 0
	Inventory.MaxAmount 120
	Ammo.BackpackAmount 0
	Ammo.BackpackMaxAmount 120
	+INVENTORY.IGNORESKILL
	Inventory.Icon "NLMGF0"
}

// --------------------------------------------------------------------------
//
// Nailgun
//	
// --------------------------------------------------------------------------


ACTOR PB_Nailgun : PB_Weapon
{
	//$Category Project Brutality - Weapons
	//$Sprite NLMGF0
	Game Doom
	SpawnID 9440
	//Weapon.SelectionOrder 2800
	Weapon.AmmoType1 "PB_HighCalMag"
	Weapon.AmmoType2 "PB_NailgunAmmo"
	Weapon.AmmoGive 30
	Weapon.AmmoUse1 0
	Weapon.AmmoUse2 0
	+FLOORCLIP
	+DONTGIB
	+WEAPON.NOAUTOAIM
	Inventory.PickupSound "CBOXPKUP"
	Inventory.PickupMessage "MIXOM Perforator-240 Nailgun (Slot 5)"
	Obituary "%o became a leaking piece of meat by %k's perforator nailgun"
	AttackSound "none"
	Tag "MIXOM Perforator-240 Nailgun"
	Scale .46
	Inventory.AltHUDIcon "NLMGF0"
	PB_WeaponBase.respectItem "RespectNailgun"
	FloatBobStrength 0.5
	PB_WeaponBase.OffsetRecoilX 3.2
	PB_WeaponBase.OffsetRecoilY 1.5
	PB_WeaponBase.MaxOverheat 1200
	States
	{
		Spawn:
			VNGN F 0 NoDelay
			NLMG F 10 A_PbvpFramework("VNGN")
			"####" "#" 0 A_PbvpInterpolate()
			LOOP
		Steady:
			TNT1 A 1
			Goto Ready
			
		WeaponSpecial:
			TNT1 A 0 A_JumpIfInventory ("GrabbedBarrel", 1, "IdleBarrel")
			TNT1 A 0 A_JumpIfInventory ("GrabbedFlameBarrel", 1, "IdleFlameBarrel")
			TNT1 A 0 A_JumpIfInventory ("GrabbedIceBarrel", 1, "IdleIceBarrel")
			TNT1 A 0 A_SetInventory("GoWeaponSpecialAbility", 0)
			TNT1 A 0 A_JumpIfInventory("JavelinMode", 1, "SwitchToNailgun")
		
		SwitchToJavelin:
			TNT1 A 0 {
				A_Print("$PB_NAILGUN_JAVELIN");
				A_SetCrosshair(-1);
				A_Setinventory("PB_LockScreenTilt",1);
				A_StartSound("weapons/nailgun/up", CHAN_AUTO);
			}
			N6N0 ABCD 1 
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect6", CHAN_AUTO)
			N6N0 EFGHIJKLMNOPQ 1
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect4", CHAN_AUTO)
			N6N0 RSTUVWXYZ 1
			N6N1 ABCDEF 1 
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect8", CHAN_AUTO)
			N6N1 GHIJ 1
			TNT1 A 0 A_JumpIfInventory("PB_NailgunAmmo",1,2)
			TNT1 A 0 PB_SpawnCasing("EmptyNailgunDrum", 12, 2.5, 10.25,frandom(2,5),frandom(1,3),frandom(2,4))
			N6N1 KL 1
			TNT1 A 0 A_StartSound("weapons/nailgun/modeswitch", CHAN_AUTO)
			N6N1 MNOPQRSTUVWXYZ 1
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect2", CHAN_AUTO)
			N6N2 ABCDEFGHIJKLMNOPQRSTU 1
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect3", CHAN_AUTO)
			N6N2 VWXYZ 1
			N6N3 ABCDEFG 1
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect4", CHAN_AUTO)
			N6N3 HIJKLMNOPQRST 1 
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect2", CHAN_AUTO)
			N6N3 UVV 1 
			TNT1 A 0 A_StartSound("weapons/nailgun/loadjavelin", CHAN_AUTO)
			N6N3 WXYZ 1
			N6N4 ABCDEFGHIJKLM 1
			TNT1 A 0 {
				PB_HandleCrosshair(76);
				A_Setinventory("PB_LockScreenTilt",0);
				A_SetInventory("JavelinMode",1);
				PB_UnloadMag("PB_NailgunAmmo","PB_HighCalMag",1,1,0,CountInv("PB_NailgunAmmo") - CountInv("PB_NailgunAmmo") % 20);
				A_SetInventory("PB_NailgunAmmo",CountInv("PB_NailgunAmmo") / 20);
				SetAmmoCapacity("PB_NailgunAmmo",6);
				PB_AmmoIntoMag("PB_NailgunAmmo","PB_HighCalMag",5,20);
			}
			Goto Ready3
			
		SwitchToNailgun:
			TNT1 A 0 {
				A_Print("$PB_NAILGUN_NAIL");
				A_SetCrosshair(-1);
				A_Setinventory("PB_LockScreenTilt",1);
				A_StartSound("weapons/nailgun/up", CHAN_AUTO);
			}
			N7N0 ABCDEFG 1 
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect2", CHAN_AUTO)
			N7N0 HIJKLM 1 
			TNT1 A 0 A_StartSound("weapons/nailgun/loadjavelin", CHAN_AUTO)
			N7N0 NOPQRSTUVWXYZ 1
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect3", CHAN_AUTO)
			N7N1 ABCDEFGH 1 
			TNT1 A 0 A_StartSound("weapons/nailgun/modeswitch", CHAN_AUTO)
			N7N1 IJKLMNOPQRSTUVWXYZ 1
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect4", CHAN_AUTO)
			N7N2 ABCDEFGHI 1 
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect2", CHAN_AUTO)
			N7N2 JKLMNO 1
			TNT1 A 0 A_JumpIfInventory("PB_NailgunAmmo",1,2)
			TNT1 A 0 PB_SpawnCasing("EmptyNailgunDrum_Javelin", 12, 2.5, 10.25,frandom(2,5),frandom(1,3),frandom(2,4))
			N7N2 PQRSTUVWXYZ 1
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect6", CHAN_AUTO)
			N7N3 ABCDEFGHIJKLMNOPQRSTUVWXYZ 1
			N7N4 ABCDEFGHIJK 1 
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect7", CHAN_AUTO)
			N7N4 LMNOPQRSTUVWXYZ 1
			N7N5 AB 1
			TNT1 A 0 {
				PB_HandleCrosshair(76);
				A_Setinventory("PB_LockScreenTilt",0);
				A_SetInventory("JavelinMode",0);
				PB_AmmoIntoMag("PB_NailgunAmmo","PB_HighCalMag",6,20);
				SetAmmoCapacity("PB_NailgunAmmo",120);
				A_SetInventory("PB_NailgunAmmo",CountInv("PB_NailgunAmmo") * 20);
			}
			Goto Ready3
		 
		Ready:
			TNT1 A 0 PB_RespectIfNeeded
		WeaponRespect:
			TNT1 A 0
			TNT1 A 0 {
				A_SetCrosshair(-1);
				A_Setinventory("PB_LockScreenTilt",1);
				A_StartSound("weapons/nailgun/up", CHAN_AUTO);
				A_SetInventory("RespectNailgun", 1);
			}
			N0N0 ABCDEFGHIJ 1 A_DoPBWeaponAction
			
			N0N0 KLMNOPQRSTU 1 {
				A_Setroll(roll-0.5, SPF_INTERPOLATE);
				A_DoPBWeaponAction;
			}
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect1", CHAN_AUTO)
			N0N0 VWXYZ 1 {
				A_Setroll(roll+0.5, SPF_INTERPOLATE);
				A_DoPBWeaponAction;
			}
			N0N1 ABCDEF 1 {
				A_Setroll(roll+0.5, SPF_INTERPOLATE);
				A_DoPBWeaponAction;
			}
			N0N1 GHIJKLMNOP 1 A_DoPBWeaponAction//QRSTUVWXYZ 1 A_DoPBWeaponAction
			//
			N0N2 H 1 A_DoPBWeaponAction
			TNT1 A 0 A_StartSound("IronSights", CHAN_AUTO)
			N0N2 IJKLMNO 1 {
				A_Setroll(roll+0.4, SPF_INTERPOLATE);
				A_DoPBWeaponAction;
			}
			N0N2 PQRSTUV 1 {
				A_Setroll(roll-0.4, SPF_INTERPOLATE);
				A_DoPBWeaponAction;
			}
			
			N0N2 WX 1 A_DoPBWeaponAction
			
			
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect2", CHAN_AUTO)
			N0N2 YZ 1 A_DoPBWeaponAction
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect3", CHAN_AUTO)
			N0N3 ABCDEFGHIJKLMNOPQ 1 A_DoPBWeaponAction
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect4", CHAN_AUTO)
			N0N3 RSTUVWXYZ 1 A_DoPBWeaponAction
			N0N4 ABCDEFGH 1 {
				A_Setroll(roll-0.4, SPF_INTERPOLATE);
				A_DoPBWeaponAction;
			}
			N0N4 IJKLMNOPQRSTUVWX 1 {
				A_Setroll(roll+0.2, SPF_INTERPOLATE);
				A_DoPBWeaponAction;
			}
			
			N0N4 YZ 1
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect8", CHAN_AUTO)
			N0N5 ABCDE 1 {
				A_Setroll(roll+0.2, SPF_INTERPOLATE);
				A_DoPBWeaponAction;
			}
			TNT1 A 0 A_PlaySound("weapons/nailgun/inspect4")
			N0N5 FGHIJKLMNO 1 {
				A_Setroll(roll+0.2, SPF_INTERPOLATE);
				A_DoPBWeaponAction;
			}
			
			
			N0N5 PQ 1 {
				A_Setroll(roll-0.2, SPF_INTERPOLATE);
				A_DoPBWeaponAction;
			}
			N0N5 RS 1 {
				A_Setroll(roll-0.2, SPF_INTERPOLATE);
				A_DoPBWeaponAction;
			}
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect6", CHAN_AUTO)
			N0N5 TUVWXYZ 1 {
				A_Setroll(roll-0.2, SPF_INTERPOLATE);
				A_DoPBWeaponAction;
			}
			N0N6 AB 1 {
				A_Setroll(roll-0.2, SPF_INTERPOLATE);
				A_DoPBWeaponAction;
			}
			
			N0N6 CD 1
			N0N6 EFGHIJ 1 {
				A_Setroll(roll-0.2, SPF_INTERPOLATE);
				A_DoPBWeaponAction;
			}
			
			N0N6 KLMNOPQRSTUV 1 {
				A_Setroll(roll+0.2, SPF_INTERPOLATE);
				A_DoPBWeaponAction;
			}
			
			N0N6 WXYZ 1 {
				A_Setroll(roll-0.3, SPF_INTERPOLATE);
				A_DoPBWeaponAction;
				}
			TNT1 A 0 {
				A_StartSound("weapons/nailgun/inspect7", CHAN_AUTO);
				A_Setroll(0);
				}
			N0N7 ABCDEFGHIJKLMNOPQRST 1 A_DoPBWeaponAction
			Goto Ready3
			
		SelectAnimation:
			J0N0 A 0 //Initialize Frames into virtual memory
			J0N1 A 0
			J0N2 A 0
			J0N3 A 0
			N1N1 A 0
			N1N2 A 0
			TNT1 A 0 A_JumpIfInventory("GoFatality",1,"Steady")
			TNT1 A 0 A_StartSound("weapons/nailgun/up", CHAN_AUTO)
			N1N0 ABCD 1 {
				if (PB_GetChamberEmpty) {A_SetWeaponSprite("N1N1");}
				if (PB_GetMagUnloaded) {A_SetWeaponSprite("N1N2");}
				if(CountInv("JavelinMode") == 1) {
					A_SetWeaponSprite("J0N0");
					if(PB_GetChamberEmpty && PB_GetMagUnloaded) {A_SetWeaponSprite("J0N2");}
					else if(PB_GetChamberEmpty) {A_SetWeaponSprite("J0N1");}
					else if(PB_GetMagUnloaded) {A_SetWeaponSprite("J0N3");}
				}
			}
		
		//Nailgun
		Ready3:
			TNT1 A 0 {
				A_Setinventory("PB_LockScreenTilt",0);
				PB_HandleCrosshair(76);
				A_SetRoll(0);
				}
		ReadyToFire:
			TNT1 A 0 A_Overlay(3,"Cooling",true)
			TNT1 A 0 A_Overlay(999,"HeatOverlayIdle")
			N1N0 D 1 {
				if (PB_GetChamberEmpty) {A_SetWeaponSprite("N1N1");}
				if (PB_GetMagUnloaded) {A_SetWeaponSprite("N1N2");}
				if(CountInv("JavelinMode") == 1) {
					A_SetWeaponSprite("J0N0");
					if(PB_GetChamberEmpty && PB_GetMagUnloaded) {A_SetWeaponSprite("J0N2");}
					else if(PB_GetChamberEmpty) {A_SetWeaponSprite("J0N1");}
					else if(PB_GetMagUnloaded) {A_SetWeaponSprite("J0N3");}
				}
				return A_DoPBWeaponAction(WRF_ALLOWRELOAD);
			}
			Loop
		Cooling:
			TNT1 A 1 PB_ModifyOverheat(-5)
			Loop
		HeatOverlayIdle:
			N8N1 ABCDEFGHI 0
			TNT1 A 0 A_JumpIf(PB_GetOverheat >= 1000, "Glow0")
			TNT1 A 0 A_JumpIf(PB_GetOverheat >= 900, "Glow1")
			TNT1 A 0 A_JumpIf(PB_GetOverheat >= 300, "Glow2")
			TNT1 A 0 A_JumpIf(PB_GetOverheat >= 240, "Glow3")
			TNT1 A 0 A_JumpIf(PB_GetOverheat >= 180, "Glow4")
			TNT1 A 0 A_JumpIf(PB_GetOverheat >= 120, "Glow5")
			TNT1 A 0 A_JumpIf(PB_GetOverheat >= 80, "Glow6")
			TNT1 A 0 A_JumpIf(PB_GetOverheat >= 40, "Glow7")
			TNT1 A 0 A_JumpIf(PB_GetOverheat >= 20, "Glow8")
			TNT1 A 1
			Stop
			Glow0: 
			TNT1 A 0 A_JumpIf(CountInv("PB_NailgunAmmo") == 0 ,2)
			N8N0 A 1 {
				//A_FireCustomMissile("GunFireSmoke", 0, 0, -2, -8, 0, 0);
				//A_FireCustomMissile("GunFireSmoke", 0, 0, 2, -8, 0, 0);
				PB_GunSmoke_Basic(-2,0,0);
				PB_GunSmoke_Basic(2,0,0);
				}
			Stop
				N8N1 A 1 {
					//A_FireCustomMissile("GunFireSmoke", 0, 0, -2, -8, 0, 0);
					//A_FireCustomMissile("GunFireSmoke", 0, 0, 2, -8, 0, 0);
					PB_GunSmoke_Basic(2,0,0);
					PB_GunSmoke_Basic(-2,0,0);
					}
				Stop
				
			Glow1: 
			TNT1 A 0 A_JumpIf(CountInv("PB_NailgunAmmo") == 0 ,2)
			N8N0 B 1 {
				//A_FireCustomMissile("GunFireSmoke", 0, 0, -2, -8, 0, 0);
				//A_FireCustomMissile("GunFireSmoke", 0, 0, 2, -8, 0, 0);
				PB_GunSmoke_Basic(2,0,0);
				PB_GunSmoke_Basic(-2,0,0);
				}
			Stop
			N8N1 B 1 {
				//A_FireCustomMissile("GunFireSmoke", 0, 0, -2, -8, 0, 0);
				//A_FireCustomMissile("GunFireSmoke", 0, 0, 2, -8, 0, 0);
				PB_GunSmoke_Basic(2,0,0);
				PB_GunSmoke_Basic(-2,0,0);
				}
			Stop
			
			Glow2:
			TNT1 A 0 A_JumpIf(CountInv("PB_NailgunAmmo") == 0 ,2)
			N8N0 C 1 {
				//A_FireCustomMissile("GunFireSmoke", 0, 0, -2, -8, 0, 0);
				//A_FireCustomMissile("GunFireSmoke", 0, 0, 2, -8, 0, 0);
				PB_GunSmoke_Basic(2,0,0);
				PB_GunSmoke_Basic(-2,0,0);
				}
			Stop
			N8N1 C 1 {
				//A_FireCustomMissile("GunFireSmoke", 0, 0, -2, -8, 0, 0);
				//A_FireCustomMissile("GunFireSmoke", 0, 0, 2, -8, 0, 0);
				PB_GunSmoke_Basic(2,0,0);
				PB_GunSmoke_Basic(-2,0,0);
				}
			Stop
			Glow3: 
			TNT1 A 0 A_JumpIf(CountInv("PB_NailgunAmmo") == 0 ,2)
			N8N0 D 1
			Stop
			N8N1 D 1
			Stop
			
			Glow4: 
			TNT1 A 0 A_JumpIf(CountInv("PB_NailgunAmmo") == 0 ,2)
			N8N0 E 1
			Stop
			N8N1 E 1
			Stop
			
			Glow5: 
			TNT1 A 0 A_JumpIf(CountInv("PB_NailgunAmmo") == 0 ,2)
			N8N0 F 1
			Stop
			N8N1 F 1
			Stop
			
			Glow6: 
			TNT1 A 0 A_JumpIf(CountInv("PB_NailgunAmmo") == 0 ,2)
			N8N0 G 1 
			Stop
			N8N1 G 1 
			Stop
			
			Glow7: 
			TNT1 A 0 A_JumpIf(CountInv("PB_NailgunAmmo") == 0 ,2)
			N8N0 H 1 
			Stop
			N8N1 H 1 
			Stop
			
			Glow8: 
			TNT1 A 0 A_JumpIf(CountInv("PB_NailgunAmmo") == 0 ,2)
			N8N0 I 1 
			Stop
			N8N1 I 1 
			Stop
		
		Deselect:
			TNT1 A 0 {
				A_WeaponOffset(0,32);
				A_SetRoll(0);
				PB_HandleCrosshair(76);
				A_ClearOverlays(3,3);
				A_Setinventory("PB_LockScreenTilt",0);
			}
	//		TNT1 A 0 A_Setinventory("Unloading",0)
			TNT1 A 0 A_Setinventory("RandomHeadExploder",0)
			TNT1 A 0 A_StopSound(6)
			TNT1 A 0 A_StopSound(4)
			TNT1 A 0 SetPlayerProperty(0,0,0)
			TNT1 A 0 A_PlaySound("weapons/changing", 1)
			
			N1N0 CEFG 1 {
				if (PB_GetChamberEmpty) {A_SetWeaponSprite("N1N1");}
				if (PB_GetMagUnloaded) {A_SetWeaponSprite("N1N2");}
				if(CountInv("JavelinMode") == 1) {
					A_SetWeaponSprite("J0N0");
					if(PB_GetChamberEmpty && PB_GetMagUnloaded) {A_SetWeaponSprite("J0N2");}
					else if(PB_GetChamberEmpty) {A_SetWeaponSprite("J0N1");}
					else if(PB_GetMagUnloaded) {A_SetWeaponSprite("J0N3");}
				}
			}
			TNT1 AAAAAAAAAAAAAAAAAA 0 A_Lower
			Wait

		Select:
			TNT1 A 0 {
				A_WeaponOffset(0,32);
				A_SetRoll(0);
				PB_HandleCrosshair(76);
				A_Setinventory("PB_LockScreenTilt",0);
				PB_ModifyOverheat(-300);
			}
			
			Goto SelectFirstPersonLegs
			SelectContinue:
			TNT1 A 0 A_TakeInventory("Overheating", 150)
			TNT1 A 0 PB_WeapTokenSwitch("NewChaingunSelected")
			TNT1 A 0 A_SetInventory("RandomHeadExploder",1)
			TNT1 AAAAAAAAAAAAAAAAAA 0 A_Raise
			TNT1 AAAAAAAA 1 A_Raise
			Wait
			

		
		
		//NailGun Fire
		Fire:
			TNT1 A 0 {
				A_WeaponOffset(0,32);
				A_SetRoll(0);
				PB_HandleCrosshair(76);
				A_Setinventory("PB_LockScreenTilt",0);
				A_ClearOverlays(3,3);
			}
			N9N0 ABCDEF 0
			N9N1 ABCDEF 0
			N9N2 ABCDEFGHIJKL 0 // Initialize frames into virtual memory
			TNT1 A 0 PB_JumpIfNoAmmo
			TNT1 A 0 A_SetInventory("RespectNailgun",1)
			TNT1 A 0 A_JumpIfInventory("JavelinMode", 1, "FireJavelin")
			TNT1 A 0 A_StartSound("weapons/nailgun/fireloop",CHAN_WEAPON, CHANF_LOOPING)
			//TNT1 A 0 A_JumpIfInventory("NailgunFiringAnimation",1, "LeftSingleFire")
		RightSingleFire:
			N2N0 A 1 {
				if (PB_GetOverheat >= 600) 
				{
					A_SetWeaponSprite("N9N2");
					A_FireCustomMissile("PB_MGNailHot", 0, 0, 2, -2, 0, 0);
				}
				else {A_FireCustomMissile("PB_MGNail", 0, 0, 2, -2, 0, 0);}
				//A_FireCustomMissile("GunFireSmoke", 0, 0, 2, -8, 0, 0);
				PB_GunSmoke_Basic(-2,0,0);
				A_Setinventory("NailgunFiringAnimation",1);
				PB_ModifyOverheat(10);
				PB_LowAmmoSoundWarning("nailgun");
				//A_Takeinventory("PB_NailgunAmmo",1);
				A_GunFlash;
				A_ZoomFactor(0.995);
				PB_WeaponRecoil(-0.52,-0.12);
			}
			N2N0 B 1 {
				A_ZoomFactor(1.0);
				if (PB_GetOverheat >= 600) {A_SetWeaponSprite("N9N2");}
				}
			//TNT1 A 0 PB_ReFire("Hold")
			//TNT1 A 0 A_StartSound("weapons/nailgun/fireStop",CHAN_WEAPON)
			/*N2N0 CDEF 1
			{
				if (PB_GetOverheat >= 600) {A_SetWeaponSprite("N9N2");}
			}*/
			//Goto Ready3
		LeftSingleFire:
			N2N0 G 1 {
				if (PB_GetOverheat >= 600) 
				{
					A_SetWeaponSprite("N9N2");
					A_FireCustomMissile("PB_MGNailHot", 0, 0, -2, -2, 0, 0);
				}
				else {A_FireCustomMissile("PB_MGNail", 0, 0, -2, -2, 0, 0);}
				//A_FireCustomMissile("GunFireSmoke", 0, 0, -2, -8, 0, 0);
				PB_GunSmoke_Basic(2,0,0);
				PB_ModifyOverheat(10);
				A_Setinventory("NailgunFiringAnimation",0);
				PB_LowAmmoSoundWarning("nailgun");
				PB_TakeAmmo("PB_NailgunAmmo",1,0,-1);
				A_GunFlash;
				A_ZoomFactor(0.995);
				PB_WeaponRecoil(-0.52,-0.12);
			}
			N2N0 H 1 {
				A_ZoomFactor(1.0);
				if (PB_GetOverheat >= 600) {A_SetWeaponSprite("N9N2");}
				}
			TNT1 A 0 PB_ReFire("Hold")
			TNT1 A 0 A_StartSound("weapons/nailgun/fireStop",CHAN_WEAPON)
			N2N0 IJKL 1 {
				if (PB_GetOverheat >= 600) {A_SetWeaponSprite("N9N2");}
				}
			Goto Ready3
			
			
		Hold:
			N9N0 ABCDEF 0
			N9N1 ABCDEF 0
			N9N2 ABCDEFGHIJKL 0 // Initialize frames into virtual memory
			TNT1 A 0 {
				A_WeaponOffset(0,32);
				PB_HandleCrosshair(76);
				}
			TNT1 A 0 A_JumpIfInventory("JavelinMode", 1, "FireJavelin")
			TNT1 A 0 A_JumpIfInventory("PB_NailgunAmmo",1,1)
			Goto Reload
			TNT1 A 0 A_StartSound("weapons/nailgun/fireloop",CHAN_WEAPON, CHANF_LOOPING)
			//TNT1 A 0 A_JumpIfInventory("NailgunFiringAnimation",1, "LeftHoldFire")
		RightHoldFire:
			TNT1 A 0 PB_FireOffset
			N2N1 A 1 {
				if (PB_GetOverheat >= 600) 
				{
					A_SetWeaponSprite("N9N0");
					A_FireCustomMissile("PB_MGNailHot", 0, 0, 2, -2, 0, 0);
				}
				else if (PB_GetOverheat >= 450) 
				{
					A_SetWeaponSprite("N9N1");
					A_FireCustomMissile("PB_MGNailHot", 0, 0, 2, -2, 0, 0);
				}
				else{A_FireCustomMissile("PB_MGNail", 0, 0, 2, -2, 0, 0);}
				//A_FireCustomMissile("GunFireSmoke", 0, 0, 2, -8, 0, 0);
				PB_GunSmoke_Basic(-2,0,0);
				PB_ModifyOverheat(10);
				A_Setinventory("NailgunFiringAnimation",1);
				PB_LowAmmoSoundWarning("nailgun");
				//A_Takeinventory("PB_NailgunAmmo",1);
				A_GunFlash;
				PB_WeaponRecoil(-0.52,-0.12);
			}
			N2N1 B 1 {
				if (PB_GetOverheat >= 450) {A_SetWeaponSprite("N9N0");}
				if (PB_GetOverheat >= 600) {A_SetWeaponSprite("N9N1");}
				}
			N2N1 C 1 {
				if (PB_GetOverheat >= 450) {A_SetWeaponSprite("N9N0");}
				if (PB_GetOverheat >= 600) {A_SetWeaponSprite("N9N1");}
			}
			//TNT1 A 0 PB_ReFire("Hold")
			//TNT1 A 0 A_StartSound("weapons/nailgun/fireStop",CHAN_WEAPON)
			TNT1 A 0 A_OverlayRotate(1,0)
			/*N2N0 DEF 1
			{
				if (CountInv("NailgunOverHeating") >= 150 ) {A_SetWeaponSprite("N9N2");}
			}
			*/
			//Goto Ready3
		LeftHoldFire:
			TNT1 A 0 PB_FireOffset
			N2N1 D 1 {
				if (PB_GetOverheat >= 600) 
				{
					A_SetWeaponSprite("N9N0");
					A_FireCustomMissile("PB_MGNailHot", 0, 0, -2, -2, 0, 0);
				}
				else if (PB_GetOverheat >= 450) 
				{
					A_SetWeaponSprite("N9N1");
					A_FireCustomMissile("PB_MGNailHot", 0, 0, -2, -2, 0, 0);
				}
				else {A_FireCustomMissile("PB_MGNail", 0, 0, -2, -2, 0, 0);}
				//A_FireCustomMissile("GunFireSmoke", 0, 0, -2, -8, 0, 0);
				PB_GunSmoke_Basic(2,0,0);
				PB_ModifyOverheat(5);
				A_SetInventory("NailgunFiringAnimation",0);
				PB_LowAmmoSoundWarning("nailgun");
				PB_TakeAmmo("PB_NailgunAmmo",1,0,-1);
				A_GunFlash;
				PB_WeaponRecoil(-0.52,-0.12);
			}
			N2N1 E 1 {
				if (PB_GetOverheat >= 450) {A_SetWeaponSprite("N9N0");}
				if (PB_GetOverheat >= 600) {A_SetWeaponSprite("N9N1");}
				}
			N2N1 F 1 {
				if (PB_GetOverheat >= 450) {A_SetWeaponSprite("N9N0");}
				if (PB_GetOverheat >= 600) {A_SetWeaponSprite("N9N1");}
				}
			TNT1 A 0 PB_ReFire("Hold")
			TNT1 A 0 A_StartSound("weapons/nailgun/fireStop",CHAN_WEAPON)
			N2N0 JKL 1{
				if (PB_GetOverheat >= 600) {A_SetWeaponSprite("N9N2");}
				}
			Goto Ready3
			
		Altfire:
			TNT1 A 0 {
				A_WeaponOffset(0,32);
				A_SetRoll(0);
				PB_HandleCrosshair(76);
				A_Setinventory("PB_LockScreenTilt",0);
				A_ClearOverlays(3,3);
			}
			N9N3 ABCDEFGHIJKLMNOPQRSTUVWXYZ 0 // Initialize frames into virtual memory
			TNT1 A 0 A_JumpIfInventory("JavelinMode", 1, "AltFireJavelin")
			TNT1 A 0 PB_JumpIfNoAmmo("Reload",20)
			TNT1 A 0 A_StartSound("weapons/nailgun/altcharge", CHAN_AUTO)
			N5N0 ABCD 1 {
				if (PB_GetOverheat >= 600) {A_SetWeaponSprite("N9N3");}
				}
			TNT1 A 0 A_StartSound("weapons/nailgun/inspect4", CHAN_AUTO)
			N5N0 EFGHIJKLMNOPQRSTUV 1 {
				if (PB_GetOverheat >= 600) {A_SetWeaponSprite("N9N3");}
				}
			TNT1 A 0 A_FireBullets(0, 0, 1, 25, "shotpuff", 0, 250)
			TNT1 AAAAAAAAAAAAAAAAAAAA 0
			{
				if (PB_GetOverheat >= 450) {
					A_FireCustomMissile("PB_MGNailHot", Random(-10, 10), 0, -1, Random(-10, 10));
				}
				else {
					A_FireCustomMissile("PB_MGNail", Random(-10, 10), 0, -1, Random(-10, 10));
				}
			}
			N5N0 W 1 {
				if (PB_GetOverheat >= 600) {A_SetWeaponSprite("N9N3");}
				PB_ModifyOverheat(300);
				//A_FireCustomMissile("GunFireSmoke", 0, 0, -2, -8, 0, 0);
				//A_FireCustomMissile("GunFireSmoke", 0, 0, 2, -8, 0, 0);
				PB_GunSmoke_Basic(2,0,0);
				PB_GunSmoke_Basic(-2,0,0);
				A_FireCustomMissile("Alerter", 0, 0, 0, 0);
				PB_TakeAmmo("PB_NailgunAmmo",20,0,-1);
				A_ZoomFactor(0.98);
				A_StartSound("weapons/nailgun/altfire", CHAN_AUTO);
				A_GunFlash;
				PB_WeaponRecoil(-1.5,+0.5);
			}
			N5N0 X 1 { 
				if (PB_GetOverheat >= 600) {A_SetWeaponSprite("N9N3");}
				A_ZoomFactor(0.99);
				PB_WeaponRecoil(-1.5,+0.5);
			}
			N5N0 Y 1 { 
				if (PB_GetOverheat >= 600) {A_SetWeaponSprite("N9N3");}
				A_ZoomFactor(1.0);
				PB_WeaponRecoil(-1.5,+0.5);
			}
			N5N0 Y 1 { A_WeaponOffset(0, 33);
				if (PB_GetOverheat >= 600) {A_SetWeaponSprite("N9N3");}
				A_ZoomFactor(1.0);
				PB_WeaponRecoil(-1.5,+0.5);
			}
			TNT1 A 0 A_Overlay(3,"Cooling",true)
			TNT1 A 0 A_WeaponOffset(0, 32)
			N8N0 A 0 A_JumpIfInventory("PB_NailgunAmmo",20,2)
			N1N1 D 0 
			"----" AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA 1 {
				A_DoPBWeaponAction(WRF_ALLOWRELOAD | WRF_NOFIRE);
				//A_FireCustomMissile("GunFireSmoke", 0, 0, -2, -8, 0, 0);
				//A_FireCustomMissile("GunFireSmoke", 0, 0, 2, -8, 0, 0);
				PB_GunSmoke_Basic(2,0,0);
				PB_GunSmoke_Basic(-2,0,0);
			}
			Goto Ready3
		FireJavelin:
			J1N1 A 0
			J1N0 A 1 {
				A_FireCustomMissile("PB_JavelinProjectile", 0, 0, 0, 0, 0, 0);
				//A_FireCustomMissile("GunFireSmoke", 0, 0, 0, -8, 0, 0);
				//A_FireCustomMissile("GunFireSmoke", 0, 0, 0, -8, 0, 0);
				//A_FireCustomMissile("GunFireSmoke", 0, 0, 0, -8, 0, 0);
				PB_GunSmoke_Basic(0,0,0);
				PB_GunSmoke_Basic(0,0,0);
				PB_GunSmoke_Basic(0,0,0);
				A_FireCustomMissile("Alerter", 0, 0, 0, 0);
				PB_TakeAmmo("PB_NailgunAmmo",1);
				A_ZoomFactor(0.985);
				A_StartSound("weapons/nailgun/javelinfire", CHAN_AUTO);
				A_GunFlash;
				PB_WeaponRecoil(-2.5,+0.2);
				if(PB_GetMagUnloaded) {A_SetWeaponSprite("J1N1");}
