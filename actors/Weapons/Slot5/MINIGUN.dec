	SpinDown_DeathDealer:
		TNT1 A 0 {
			A_StopSound(1);
			A_StopSound(5);
			A_OverlayOffset(10,0,0);
			A_StartSound("CHAINSTO", CHAN_5,CHANF_OVERLAP);
			A_StartSound("DTHDLRSP", CHAN_5,CHANF_OVERLAP);
		}
		8HAF ABCD 1 {
			if(CountInv("PB_HighCalMag") > 0) {A_FireCustomMissile("SmokeSpawner11",0,0,0,0);}
			A_Overlay(3,"AmmoMeterOverlay");
			A_Overlayoffset(3,-27,0,WOF_ADD);
			A_Overlay(4,"AmmoBeltIdle");
			A_OverlayOffset(4,22,0,WOF_ADD);
			PB_ReFire("Fire_DeathDealer");
		}
		8HAF EEFFGGHHAABB 1 {
			if(CountInv("PB_HighCalMag") > 0) {A_FireCustomMissile("SmokeSpawner11",0,0,0,0);}
			A_Overlay(3,"AmmoMeterOverlay");
			A_Overlayoffset(3,-27,0,WOF_ADD);
			A_Overlay(4,"AmmoBeltIdle");
			A_OverlayOffset(4,22,0,WOF_ADD);
			PB_ReFire("Fire_DeathDealer");
		}
		8HAF CCCDDDEEEFFFGGGHHH 1 {
			if(CountInv("PB_HighCalMag") > 0) {A_FireCustomMissile("SmokeSpawner11",0,0,0,0);}
			A_Overlay(3,"AmmoMeterOverlay");
			A_Overlayoffset(3,-27,0,WOF_ADD);
			A_Overlay(4,"AmmoBeltIdle");
			A_OverlayOffset(4,22,0,WOF_ADD);
			PB_ReFire("Fire_DeathDealer");
		}
		goto ReadyToFire_DeathDealer
	
	FlashKicking:
		MG33 A 0
		MG35 A 0
		TNT1 A 0 {
			A_ClearOverlays(3,10);
			A_Overlay(3,"AmmoMeterOverlay");
			A_OverlayOffset(3,-1,1);
			if (CountInv("TripleBarrelMode") == 1) {A_OverlayOffset(3,-28,1);}
		}
		MG03 ABCDEFGHIJKLM 1 {
				if (CountInv("MinigunUpgraded") == 1) {A_SetWeaponSprite("MG33");}
				if (CountInv("TripleBarrelMode") == 1) {A_SetWeaponSprite("MG35");}
			}
		TNT1 A 0 {
			A_Overlay(3,"AmmoMeterOverlay");
			A_OverlayOffset(3,-1,1);
			if (CountInv("TripleBarrelMode") == 1) {A_OverlayOffset(3,-28,1);}
		}
		MG03 N 1 {
				if (CountInv("MinigunUpgraded") == 1) {A_SetWeaponSprite("MG33");}
				if (CountInv("TripleBarrelMode") == 1) {A_SetWeaponSprite("MG35");}
			}
		Goto Ready3
