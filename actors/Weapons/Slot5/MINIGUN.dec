	SpinDown:
		TNT1 A 0 A_JumpIfInventory("ChaingunMode",1,"SpinDown_Chaingun")
		TNT1 A 0 {
			A_ClearOverlays(4,4);
			A_StopSound(5);
			A_StopSound(1);
			A_StartSound("CHAINSTO", CHAN_5);
			A_Overlay(9,"Glow");
		}
		CHAG ABCD 1 {
			A_Overlay(3,"AmmoMeterOverlay");
			if (CountInv("MinigunUpgraded") == 1) {A_SetWeaponSprite("UCHG");}
			if (CountInv("PB_HighCalMag") > 0 ) { A_Overlay(4,"AmmoBeltIdle"); }
			if(CountInv("PB_HighCalMag") > 0) {A_FireCustomMissile("SmokeSpawner11",0,0,0,0);}
			A_Overlay(9,"Glow");
			return A_DoPBWeaponAction;
		}
		CHAG EEFFGGHH 1 {
			A_Overlay(3,"AmmoMeterOverlay");
			if (CountInv("MinigunUpgraded") == 1) {A_SetWeaponSprite("UCHG");}
			if (CountInv("PB_HighCalMag") > 0 ) { A_Overlay(4,"AmmoBeltIdle"); }
			if(CountInv("PB_HighCalMag") > 0) {A_FireCustomMissile("SmokeSpawner11",0,0,0,0);}
			A_Overlay(9,"Glow");
			return A_DoPBWeaponAction;
		}
		CHAG AAABBBCCCDDD 1 {
			A_Overlay(3,"AmmoMeterOverlay");
