	EmptySpin:
		TNT1 A 0 {
			A_StopSound(CHAN_WEAPON);
			A_ClearOverlays(4,4);
		}
		CHAG ABCD 1 {
			A_Overlay(9,"Glow");
			A_Overlay(3,"AmmoMeterOverlay");
			if (CountInv("MinigunUpgraded") == 1) {A_SetWeaponSprite("UCHG");}
		}
		TNT1 A 0 A_StartSound("weapons/empty",0)
		CHAG EFGH 1 {
			A_Overlay(9,"Glow");
			A_Overlay(3,"AmmoMeterOverlay");
			if (CountInv("MinigunUpgraded") == 1) {A_SetWeaponSprite("UCHG");}
		}
		TNT1 A 0 PB_Refire("Hold")
		Goto SpinDown
	Fire:
		TNT1 A 0 {
			A_WeaponOffset(0,32);
			A_SetRoll(0);
			PB_HandleCrosshair(75);
			A_SetInventory("PB_LockScreenTilt",0);
			if(CountInv("ChaingunMode") == 1) {A_StartSound("weapons/minigun/chaingunmode/spinup", CHAN_5);}
			else {A_StartSound("CHAINSTA", CHAN_5);}
		}
		TNT1 A 0 A_JumpIfInventory("TripleBarrelMode", 1, "Fire_DeathDealer")
		CHAG ABCDEFGH 1 {
			A_Overlay(9,"Glow");
			A_Overlay(3,"AmmoMeterOverlay");
			if (CountInv("MinigunUpgraded") == 1) {A_SetWeaponSprite("UCHG");}
		}
		TNT1 A 0 A_JumpIfInventory("ChainGunMode", 1, "Fire_Chaingun")
		TNT1 A 0 {
			A_StartSound("weapons/minigunfirefast", CHAN_WEAPON, CHANF_LOOPING);
			A_StartSound("CHAINSPI", CHAN_5);
			if (CountInv("MinigunUpgraded") == 1) {A_Overlay(4,"AmmoBeltAnimation");}
			else {A_Overlay(4,"AmmoBeltAnimation");}
			}
