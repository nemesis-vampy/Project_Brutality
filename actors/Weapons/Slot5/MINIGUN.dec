	EmptySpin_DeathDealer:
		TNT1 A 0 {
			A_StopSound(CHAN_WEAPON);
			A_ClearOverlays(4,4);
		}
		8HAF A 1 {
			A_Overlay(3,"AmmoMeterOverlay");
			A_Overlayoffset(3,-27,0,WOF_ADD);
		}
		8HAF BCDEFGH 1 {
			A_Overlay(3,"AmmoMeterOverlay");
			A_Overlayoffset(3,-27,0,WOF_ADD);
			A_StartSound("weapons/empty",0);
		}
