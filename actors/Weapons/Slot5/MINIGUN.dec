		// Overlay/Flash States defined below
		AmmoBeltAnimation:
			MG08 A 0
			MG07 BC 1 {if (CountInv("MinigunUpgraded") == 1) {A_SetWeaponSpriteEx("MG08");}}
			Loop
		AmmoBeltChaingun:
			MG07 BCDA 1 {if (CountInv("MinigunUpgraded") == 1) {A_SetWeaponSpriteEx("MG08");}}
			Loop
		AmmoBeltIdle:
			TNT1 A 0 A_JumpIfInventory("PB_HighCalMag",1,1)
			Stop
			MG07 A 1 {if (CountInv("MinigunUpgraded") == 1) {A_SetWeaponSpriteEx("MG08");}}
			Loop
		
		Glow:
			TNT1 A 0 {
				A_OverlayFlags(9,PSPF_RENDERSTYLE,true);
				A_OverlayRenderStyle(9,STYLE_Add);
			}
			TNT1 A 0 A_JumpIfInventory("OverHeating",90,"Glow6")
			TNT1 A 0 A_JumpIfInventory("OverHeating",75,"Glow5")
			TNT1 A 0 A_JumpIfInventory("OverHeating",60,"Glow4")
			TNT1 A 0 A_JumpIfInventory("OverHeating",45,"Glow3")
			TNT1 A 0 A_JumpIfInventory("OverHeating",35,"Glow2")
			TNT1 A 0 A_JumpIfInventory("OverHeating",20,"Glow1")
			Stop
		Glow1:
			G10W A 2 BRIGHT //BRIGHT
			Stop
		Glow2:
			G10W B 2 BRIGHT //BRIGHT
			Stop
		Glow3:
